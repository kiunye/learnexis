<div class="min-h-dvh">
  <div class="relative mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="grid items-stretch gap-10 lg:grid-cols-12">
      <section class="lg:col-span-5">
        <%= link_to root_path, class: "inline-flex items-center gap-3 group" do %>
          <span class="grid h-11 w-11 place-items-center rounded-md bg-blue-600 text-white shadow-[0_18px_40px_-25px_rgba(59,130,246,0.9)]">
            <span class="text-lg font-bold">L</span>
          </span>
          <span class="text-xl font-semibold tracking-tight text-slate-900">
            LearnExis
          </span>
        <% end %>

        <p class="mt-7 text-sm text-slate-600">
          One system for attendance, fees, invoices, classrooms, and school-wide updates — designed for admins, teachers, parents, and students.
        </p>

        <div class="mt-8 space-y-4">
          <div class="rounded-xl border border-slate-200 bg-white px-5 py-4">
            <p class="text-sm font-medium text-slate-900">Tip</p>
            <p class="mt-1 text-sm text-slate-600">
              Use the same email you received your account invite with.
            </p>
          </div>

          <div class="rounded-xl border border-slate-200 bg-white px-5 py-4">
            <p class="text-sm font-medium text-slate-900">Need access?</p>
            <p class="mt-1 text-sm text-slate-600">
              <%= link_to "Contact your school administrator", root_path, class: "font-semibold text-blue-700 hover:text-blue-800" %>
            </p>
          </div>
        </div>
      </section>

      <section class="lg:col-span-7">
        <div class="auth-card rounded-2xl p-6 sm:p-8">
          <div class="flex items-start justify-between gap-6">
            <div>
              <h1 class="text-2xl font-semibold tracking-tight text-slate-900">
                Sign in
              </h1>
              <p class="mt-2 text-sm text-slate-600">
                Welcome back — pick up exactly where you left off.
              </p>
            </div>
          </div>

          <%= form_with url: session_url, class: "mt-8 space-y-5" do |form| %>
            <div style="max-width=90%">
              <%= form.label :email_address, "Email address", class: "auth-label" %>
              <%= form.email_field :email_address,
                  required: true,
                  autofocus: true,
                  autocomplete: "username",
                  value: params[:email_address],
                  class: "auth-input box-content" %>
            </div>

            <div style="max-width=90%">
              <div class="flex items-baseline justify-between gap-3">
                <%= form.label :password, "Password", class: "auth-label" %>
                <%= link_to "Forgot password?", new_password_path, class: "text-sm font-semibold text-blue-700 hover:text-blue-800" %>
              </div>
              <%= form.password_field :password,
                  required: true,
                  autocomplete: "current-password",
                  maxlength: 72,
                  class: "auth-input" %>
            </div>

            <div class="flex items-center justify-between gap-4">
              <label class="inline-flex items-center gap-2 text-sm text-slate-600">
                <%= form.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 bg-white text-blue-600 focus:ring-4 focus:ring-blue-500/15 focus:ring-offset-0" %>
                <span>Remember me</span>
              </label>
            </div>

            <div class="pt-1">
              <%= form.submit "Sign in", class: "auth-button" %>
            </div>
          <% end %>

          <p class="mt-7 text-xs text-slate-500">
            © <%= Time.current.year %> LearnExis — secure access for your school community.
          </p>
        </div>
      </section>
    </div>
  </div>
</div>