<div class="min-h-dvh">
  <div class="relative mx-auto w-full max-w-xl px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <%= link_to new_session_path, class: "inline-flex items-center gap-2 text-sm font-semibold text-slate-700 hover:text-slate-900" do %>
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M12.79 15.79a1 1 0 01-1.41 0l-5-5a1 1 0 010-1.41l5-5a1 1 0 011.41 1.41L8.41 9H17a1 1 0 110 2H8.41l4.38 4.38a1 1 0 010 1.41z" clip-rule="evenodd" />
      </svg>
      Back to sign in
    <% end %>

    <div class="auth-card mt-6 rounded-2xl p-6 sm:p-8">
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">Choose a new password</h1>
      <p class="mt-2 text-sm text-slate-600">
        Use at least 8 characters. Longer is better.
      </p>

      <%= form_with url: password_path(params[:token]), method: :put, class: "mt-7 space-y-5" do |form| %>
        <div>
          <%= form.label :password, "New password", class: "auth-label" %>
          <%= form.password_field :password,
              required: true,
              autocomplete: "new-password",
              maxlength: 72,
              class: "auth-input" %>
        </div>

        <div>
          <%= form.label :password_confirmation, "Confirm new password", class: "auth-label" %>
          <%= form.password_field :password_confirmation,
              required: true,
              autocomplete: "new-password",
              maxlength: 72,
              class: "auth-input" %>
        </div>

        <div class="pt-1">
          <%= form.submit "Save password", class: "auth-button" %>
        </div>
      <% end %>

      <p class="mt-7 text-xs text-slate-500">
        © <%= Time.current.year %> LearnExis
      </p>
    </div>
  </div>
</div>