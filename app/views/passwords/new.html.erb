<div class="min-h-dvh">
  <div class="relative mx-auto w-full max-w-xl px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <%= link_to new_session_path, class: "inline-flex items-center gap-2 text-sm font-semibold text-slate-700 hover:text-slate-900" do %>
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M12.79 15.79a1 1 0 01-1.41 0l-5-5a1 1 0 010-1.41l5-5a1 1 0 011.41 1.41L8.41 9H17a1 1 0 110 2H8.41l4.38 4.38a1 1 0 010 1.41z" clip-rule="evenodd" />
      </svg>
      Back to sign in
    <% end %>

    <div class="auth-card mt-6 rounded-2xl p-6 sm:p-8">
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">Reset your password</h1>
      <p class="mt-2 text-sm text-slate-600">
        Enter your email address and we’ll send instructions. If the email isn’t on file, nothing will be sent.
      </p>

      <%= form_with url: passwords_path, class: "mt-7 space-y-5" do |form| %>
        <div>
          <%= form.label :email_address, "Email address", class: "auth-label" %>
          <%= form.email_field :email_address,
              required: true,
              autofocus: true,
              autocomplete: "username",
              value: params[:email_address],
              class: "auth-input box-content" %>
        </div>

        <div class="pt-1">
          <%= form.submit "Email reset instructions", class: "auth-button" %>
        </div>
      <% end %>

      <p class="mt-7 text-xs text-slate-500">
        © <%= Time.current.year %> LearnExis
      </p>
    </div>
  </div>
</div>