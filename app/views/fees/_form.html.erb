<%= form_with model: fee, local: true, class: "space-y-6" do |f| %>
  <% if fee.errors.any? %>
    <div class="alert alert-error">
      <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <h3 class="font-bold">Please fix the following errors:</h3>
        <ul class="list-disc list-inside">
          <% fee.errors.full_messages.each do |error| %>
            <li><%= error %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="card bg-gray-800 border border-gray-700 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-xl mb-4 text-gray-100">Fee Information</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-control">
          <%= f.label :name, class: "label" do %>
            <span class="label-text text-gray-300">Name <span class="text-error">*</span></span>
          <% end %>
          <%= f.text_field :name,
              class: "input input-bordered w-full",
              placeholder: "e.g., Grade 1 Tuition 2025",
              required: true %>
        </div>

        <div class="form-control">
          <%= f.label :fee_type, class: "label" do %>
            <span class="label-text text-gray-300">Type <span class="text-error">*</span></span>
          <% end %>
          <%= f.select :fee_type,
              options_for_select([
                [ "Tuition", "tuition" ],
                [ "Transport", "transport" ],
                [ "Other", "other" ]
              ], fee.fee_type),
              {},
              { class: "select select-bordered w-full", required: true } %>
        </div>

        <div class="form-control">
          <%= f.label :amount, class: "label" do %>
            <span class="label-text text-gray-300">Amount <span class="text-error">*</span></span>
          <% end %>
          <%= f.number_field :amount,
              class: "input input-bordered w-full",
              required: true,
              min: 0,
              step: 0.01,
              placeholder: "0.00" %>
        </div>

        <div class="form-control">
          <%= f.label :academic_year, class: "label" do %>
            <span class="label-text text-gray-300">Academic Year <span class="text-error">*</span></span>
          <% end %>
          <%= f.number_field :academic_year,
              class: "input input-bordered w-full",
              required: true,
              min: 2000,
              max: 2100 %>
        </div>

        <div class="form-control">
          <%= f.label :status, class: "label" do %>
            <span class="label-text text-gray-300">Status</span>
          <% end %>
          <%= f.select :status,
              options_for_select([
                [ "Active", "active" ],
                [ "Inactive", "inactive" ]
              ], fee.status),
              {},
              { class: "select select-bordered w-full" } %>
        </div>

        <div class="form-control">
          <%= f.label :due_date, class: "label" do %>
            <span class="label-text text-gray-300">Due Date</span>
          <% end %>
          <%= f.date_field :due_date,
              class: "input input-bordered w-full" %>
        </div>
      </div>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", fee.persisted? ? fee_path(fee) : fees_path, class: "btn btn-ghost", data: { turbo_frame: "_top" } %>
    <%= f.submit fee.persisted? ? "Update Fee" : "Create Fee", class: "btn btn-primary" %>
  </div>
<% end %>
