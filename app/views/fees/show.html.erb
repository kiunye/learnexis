<% content_for :title, @fee.name %>

<div>
  <div class="mb-6 flex justify-between items-center">
    <div>
      <div class="breadcrumbs text-sm mb-2">
        <ul>
          <li><%= link_to "Fees", fees_path, class: "text-blue-600 hover:text-blue-700" %></li>
          <li><%= @fee.name %></li>
        </ul>
      </div>
      <h1 class="text-3xl font-bold text-gray-100"><%= @fee.name %></h1>
      <p class="text-gray-600 mt-1">
        <span class="badge badge-outline text-gray-900"><%= @fee.fee_type.humanize %></span>
        • Academic Year <%= @fee.academic_year %>
        <% if @fee.active? %>
          <span class="badge badge-success ml-1">Active</span>
        <% else %>
          <span class="badge badge-ghost text-gray-600 ml-1">Inactive</span>
        <% end %>
      </p>
    </div>
    <div class="flex gap-2">
      <% if policy(@fee).update? %>
        <%= link_to edit_fee_path(@fee), class: "btn btn-primary", data: { turbo_frame: "_top" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          Edit
        <% end %>
      <% end %>
      <% if policy(@fee).assign_students? %>
        <%= link_to assign_students_fee_path(@fee), class: "btn btn-secondary", data: { turbo_frame: "_top" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Assign Students
        <% end %>
      <% end %>
      <%= link_to fees_path, class: "btn btn-ghost" do %>
        Back to List
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <div class="card bg-gray-800 border border-gray-700 shadow-md">
        <div class="card-body">
          <h2 class="card-title text-xl mb-4 text-gray-100">Fee Details</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="label">
                <span class="label-text font-medium text-gray-300">Amount</span>
              </label>
              <p class="text-gray-300 text-lg"><%= number_to_currency(@fee.amount) %></p>
            </div>
            <div>
              <label class="label">
                <span class="label-text font-medium text-gray-300">Due Date</span>
              </label>
              <p class="text-gray-300"><%= @fee.due_date ? l(@fee.due_date) : "—" %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="card bg-gray-800 border border-gray-700 shadow-md">
        <div class="card-body">
          <div class="flex justify-between items-center mb-4">
            <h2 class="card-title text-xl text-gray-100">Assigned Students (<%= @fee_assignments.count %>)</h2>
          </div>
          <div class="overflow-x-auto">
            <table class="table table-zebra w-full">
              <thead>
                <tr>
                  <th class="text-gray-100">Student</th>
                  <th class="text-gray-100">Admission #</th>
                  <th class="text-gray-100">Status</th>
                  <th class="text-gray-100">Effective Amount</th>
                </tr>
              </thead>
              <tbody>
                <% if @fee_assignments.any? %>
                  <% @fee_assignments.each do |fa| %>
                    <% calc = FeeCalculationService.calculate(fa) %>
                    <tr>
                      <td class="text-gray-300"><%= fa.student.full_name %></td>
                      <td class="text-gray-300"><%= fa.student.admission_number %></td>
                      <td>
                        <% case fa.status %>
                        <% when "pending" %>
                          <span class="badge badge-warning">Pending</span>
                        <% when "partial" %>
                          <span class="badge badge-info">Partial</span>
                        <% when "paid" %>
                          <span class="badge badge-success">Paid</span>
                        <% when "cancelled" %>
                          <span class="badge badge-ghost text-gray-600">Cancelled</span>
                        <% else %>
                          <span class="badge badge-ghost"><%= fa.status %></span>
                        <% end %>
                      </td>
                      <td class="text-gray-300">
                        <% if fa.exempt? %>
                          <span class="text-gray-600">Exempt</span>
                        <% else %>
                          <%= number_to_currency(calc.net_amount) %>
                          <% if calc.installment_count > 1 %>
                            <span class="text-gray-600 text-sm">(<%= calc.installment_count %> × <%= number_to_currency(calc.per_installment) %>)</span>
                          <% end %>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="4" class="text-center text-gray-300 py-8">
                      No students assigned. Use "Assign Students" to add students to this fee.
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="card bg-gray-800 border border-gray-700 shadow-md">
        <div class="card-body">
          <h2 class="card-title text-lg mb-4 text-gray-100">Summary</h2>
          <div class="stats stats-vertical shadow w-full">
            <div class="stat">
              <div class="stat-title text-gray-600">Base Amount</div>
              <div class="stat-value text-primary"><%= number_to_currency(@fee.amount) %></div>
            </div>
            <div class="stat">
              <div class="stat-title text-gray-600">Assignments</div>
              <div class="stat-value text-success"><%= @fee_assignments.count %></div>
              <div class="stat-desc text-gray-600">students assigned</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
