<% content_for :title, "Edit Invoice ##{@invoice.id}" %>

<div>
  <div class="mb-6">
    <div class="breadcrumbs text-sm mb-2">
      <ul>
        <li><%= link_to "Invoices", invoices_path, class: "text-blue-600 hover:text-blue-700" %></li>
        <li><%= link_to "##{@invoice.id}", invoice_path(@invoice), class: "text-blue-600 hover:text-blue-700" %></li>
        <li>Edit</li>
      </ul>
    </div>
    <h1 class="text-3xl font-bold text-gray-100">Edit Invoice</h1>
    <p class="text-gray-600 mt-1">Invoice #<%= @invoice.id %> – <%= @invoice.student.full_name %>. To add line items, use <strong>Bulk Generate</strong> when creating new invoices from fee assignments.</p>
  </div>

  <%= render "form", invoice: @invoice %>
</div>
