<% content_for :title, "Invoice ##{@invoice.id}" %>

<div>
  <div class="mb-6 flex justify-between items-center">
    <div>
      <div class="breadcrumbs text-sm mb-2">
        <ul>
          <li><%= link_to "Invoices", invoices_path, class: "text-blue-600 hover:text-blue-700" %></li>
          <li>Invoice #<%= @invoice.id %></li>
        </ul>
      </div>
      <h1 class="text-3xl font-bold text-gray-100">Invoice #<%= @invoice.id %></h1>
      <p class="text-gray-600 mt-1">
        <%= @invoice.student.full_name %> • <%= @invoice.issue_date.strftime("%d %b %Y") %> – <%= @invoice.due_date.strftime("%d %b %Y") %>
        <% case @invoice.status %>
        <% when "draft" %>
          <span class="badge badge-ghost text-gray-600 ml-1">Draft</span>
        <% when "pending" %>
          <span class="badge badge-warning ml-1">Pending</span>
        <% when "paid" %>
          <span class="badge badge-success ml-1">Paid</span>
        <% when "overdue" %>
          <span class="badge badge-error ml-1">Overdue</span>
        <% when "cancelled" %>
          <span class="badge badge-ghost text-gray-600 ml-1">Cancelled</span>
        <% end %>
      </p>
    </div>
    <div class="flex gap-2">
      <% if policy(Transaction).create? && (@invoice.pending? || @invoice.overdue?) %>
        <%= link_to new_transaction_path(invoice_id: @invoice.id), class: "btn btn-primary", data: { turbo_frame: "_top" } do %>
          Record Payment
        <% end %>
      <% end %>
      <% if policy(@invoice).download? %>
        <%= link_to download_invoice_path(@invoice), class: "btn btn-secondary", target: "_blank", rel: "noopener" do %>
          Download PDF
        <% end %>
      <% end %>
      <% if policy(@invoice).update? %>
        <%= link_to edit_invoice_path(@invoice), class: "btn btn-secondary", data: { turbo_frame: "_top" } do %>
          Edit
        <% end %>
      <% end %>
      <%= link_to invoices_path, class: "btn btn-ghost" do %>
        Back to List
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <div class="card bg-gray-800 border border-gray-700 shadow-md">
        <div class="card-body">
          <h2 class="card-title text-xl mb-4 text-gray-100">Line Items</h2>
          <div class="overflow-x-auto">
            <table class="table table-zebra w-full">
              <thead>
                <tr>
                  <th class="text-gray-100">Description</th>
                  <th class="text-gray-100">Qty</th>
                  <th class="text-gray-100">Unit Amount</th>
                  <th class="text-gray-100">Amount</th>
                </tr>
              </thead>
              <tbody>
                <% if @invoice_line_items.any? %>
                  <% @invoice_line_items.each do |line| %>
                    <tr>
                      <td class="text-gray-300"><%= line.description %></td>
                      <td class="text-gray-300"><%= line.quantity %></td>
                      <td class="text-gray-300"><%= number_to_currency(line.unit_amount) %></td>
                      <td class="text-gray-300"><%= number_to_currency(line.amount) %></td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="4" class="text-center text-gray-300 py-6">No line items.</td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <div class="mt-4 flex justify-end">
            <p class="text-lg font-bold text-gray-100">Total: <%= number_to_currency(@invoice.total_amount) %></p>
          </div>
        </div>
      </div>

      <% if @invoice.notes.present? %>
        <div class="card bg-gray-800 border border-gray-700 shadow-md">
          <div class="card-body">
            <h2 class="card-title text-lg text-gray-100">Notes</h2>
            <p class="text-gray-300"><%= @invoice.notes %></p>
          </div>
        </div>
      <% end %>
    </div>

    <div class="space-y-6">
      <div class="card bg-gray-800 border border-gray-700 shadow-md">
        <div class="card-body">
          <h2 class="card-title text-lg mb-4 text-gray-100">Details</h2>
          <div class="space-y-3">
            <div>
              <label class="label">
                <span class="label-text text-gray-600">Student</span>
              </label>
              <p class="text-gray-300"><%= @invoice.student.full_name %></p>
              <p class="text-sm text-gray-600"><%= @invoice.student.admission_number %></p>
            </div>
            <div>
              <label class="label">
                <span class="label-text text-gray-600">Issue Date</span>
              </label>
              <p class="text-gray-300"><%= @invoice.issue_date.strftime("%d %b %Y") %></p>
            </div>
            <div>
              <label class="label">
                <span class="label-text text-gray-600">Due Date</span>
              </label>
              <p class="text-gray-300"><%= @invoice.due_date.strftime("%d %b %Y") %></p>
            </div>
            <div>
              <label class="label">
                <span class="label-text text-gray-600">Status</span>
              </label>
              <% case @invoice.status %>
              <% when "draft" %>
                <span class="badge badge-ghost text-gray-600">Draft</span>
              <% when "pending" %>
                <span class="badge badge-warning">Pending</span>
              <% when "paid" %>
                <span class="badge badge-success">Paid</span>
              <% when "overdue" %>
                <span class="badge badge-error">Overdue</span>
              <% when "cancelled" %>
                <span class="badge badge-ghost text-gray-600">Cancelled</span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
