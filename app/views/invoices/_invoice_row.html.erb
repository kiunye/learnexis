<tr>
  <td class="text-gray-300 font-medium">
    <%= link_to "##{invoice.id}", invoice_path(invoice), class: "link link-hover text-gray-100" %>
  </td>
  <td class="text-gray-300"><%= invoice.student.full_name %></td>
  <td class="text-gray-300"><%= invoice.issue_date.strftime("%d %b %Y") %></td>
  <td class="text-gray-300"><%= invoice.due_date.strftime("%d %b %Y") %></td>
  <td class="text-gray-300"><%= number_to_currency(invoice.total_amount) %></td>
  <td>
    <% case invoice.status %>
    <% when "draft" %>
      <span class="badge badge-ghost text-gray-600">Draft</span>
    <% when "pending" %>
      <span class="badge badge-warning">Pending</span>
    <% when "paid" %>
      <span class="badge badge-success">Paid</span>
    <% when "overdue" %>
      <span class="badge badge-error">Overdue</span>
    <% when "cancelled" %>
      <span class="badge badge-ghost text-gray-600">Cancelled</span>
    <% else %>
      <span class="badge badge-outline text-gray-900"><%= invoice.status.humanize %></span>
    <% end %>
  </td>
  <td>
    <%= link_to "View", invoice_path(invoice), class: "btn btn-ghost btn-sm", data: { turbo_frame: "_top" } %>
    <% if policy(invoice).download? %>
      <%= link_to "PDF", download_invoice_path(invoice), class: "btn btn-ghost btn-sm", target: "_blank", rel: "noopener" %>
    <% end %>
    <% if policy(invoice).update? %>
      <%= link_to "Edit", edit_invoice_path(invoice), class: "btn btn-ghost btn-sm", data: { turbo_frame: "_top" } %>
    <% end %>
  </td>
</tr>
