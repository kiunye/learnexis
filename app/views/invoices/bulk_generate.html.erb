<% content_for :title, "Bulk Generate Invoices" %>

<div>
  <div class="mb-6 flex justify-between items-center">
    <div>
      <div class="breadcrumbs text-sm mb-2">
        <ul>
          <li><%= link_to "Invoices", invoices_path, class: "text-blue-600 hover:text-blue-700" %></li>
          <li>Bulk Generate</li>
        </ul>
      </div>
      <h1 class="text-3xl font-bold text-gray-100">Bulk Generate Invoices</h1>
      <p class="text-gray-600 mt-1">Create draft invoices from pending fee assignments for selected students</p>
    </div>
    <%= link_to invoices_path, class: "btn btn-ghost" do %>
      Back to Invoices
    <% end %>
  </div>

  <%= form_with url: bulk_generate_invoices_path, method: :post, local: true, class: "space-y-4" do |f| %>
    <div class="card bg-gray-800 border border-gray-700 shadow-md">
      <div class="card-body">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
          <div class="form-control">
            <%= f.label :issue_date, class: "label" do %>
              <span class="label-text text-gray-300">Issue Date <span class="text-error">*</span></span>
            <% end %>
            <%= f.date_field :issue_date, value: Date.current, class: "input input-bordered w-full", required: true %>
          </div>
          <div class="form-control">
            <%= f.label :due_date, class: "label" do %>
              <span class="label-text text-gray-300">Due Date <span class="text-error">*</span></span>
            <% end %>
            <%= f.date_field :due_date, value: (Date.current + 30.days), class: "input input-bordered w-full", required: true %>
          </div>
        </div>

        <div class="form-control">
          <label class="label">
            <span class="label-text text-gray-300 font-medium">Select Students</span>
          </label>
          <div class="max-h-96 overflow-y-auto border border-gray-700 rounded-lg p-4 space-y-2">
            <% if @students.any? %>
              <% @students.each do |student| %>
                <label class="flex items-center gap-3 cursor-pointer hover:bg-gray-700 p-2 rounded">
                  <%= check_box_tag "student_ids[]", student.id, false, class: "checkbox checkbox-primary" %>
                  <div class="flex-1">
                    <p class="font-medium text-gray-100"><%= student.full_name %></p>
                    <p class="text-sm text-gray-600"><%= student.admission_number %> <% if student.classroom %>(<%= student.classroom.name %>)<% end %></p>
                  </div>
                </label>
              <% end %>
            <% else %>
              <p class="text-gray-600 text-center py-4">No students available in your scope.</p>
            <% end %>
          </div>
        </div>

        <div class="flex gap-2 mt-6">
          <%= link_to "Cancel", invoices_path, class: "btn btn-ghost", data: { turbo_frame: "_top" } %>
          <%= f.submit "Generate Invoices", class: "btn btn-primary", disabled: @students.empty? %>
        </div>
      </div>
    </div>
  <% end %>
</div>
