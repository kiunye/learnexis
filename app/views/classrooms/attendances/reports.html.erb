<% content_for :title, "Attendance Report - #{@classroom.name}" %>

<div>
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:justify-between sm:items-start">
    <div>
      <div class="breadcrumbs text-sm mb-2">
        <ul>
          <li><%= link_to "Classrooms", classrooms_path, class: "link link-hover link-primary" %></li>
          <li><%= link_to @classroom.name, classroom_path(@classroom), class: "link link-hover link-primary" %></li>
          <li><%= link_to "Attendance", classroom_attendances_path(@classroom), class: "link link-hover link-primary" %></li>
          <li>Reports</li>
        </ul>
      </div>
      <h1 class="text-3xl font-bold text-base-content">Class attendance report</h1>
      <p class="text-base-content/70 mt-1"><%= @classroom.name %> · <%= @start_date.strftime("%b %d, %Y") %> – <%= @end_date.strftime("%b %d, %Y") %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <% if policy(@classroom).update? %>
        <%= link_to mark_classroom_attendances_path(@classroom, date: Date.current), class: "btn btn-primary btn-sm" do %>
          Mark today
        <% end %>
      <% end %>
      <%= link_to classroom_attendances_path(@classroom), class: "btn btn-outline btn-sm" do %>
        Register
      <% end %>
      <% if policy(:report).attendance? %>
        <%= link_to attendance_reports_path, class: "btn btn-ghost btn-sm" do %>
          All-school report
        <% end %>
      <% end %>
    </div>
  </div>

  <%= form_with url: reports_classroom_attendances_path(@classroom), method: :get, local: true, class: "card bg-base-200 border border-base-300 shadow-sm mb-6" do |f| %>
    <div class="card-body">
      <h2 class="card-title text-base text-base-content mb-4">Date range</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
        <div class="form-control">
          <label class="label pt-0"><span class="label-text font-medium">Start</span></label>
          <%= f.date_field :start_date, value: @start_date, class: "input input-bordered w-full" %>
        </div>
        <div class="form-control">
          <label class="label pt-0"><span class="label-text font-medium">End</span></label>
          <%= f.date_field :end_date, value: @end_date, class: "input input-bordered w-full" %>
        </div>
        <div>
          <%= f.submit "Update report", class: "btn btn-primary" %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="card bg-base-200 border border-base-300 shadow-sm">
      <div class="card-body">
        <div class="stat-title text-base-content/60">Records in range</div>
        <div class="stat-value text-primary"><%= @report[:attendances].count %></div>
        <div class="stat-desc text-base-content/55">Saved marks</div>
      </div>
    </div>
    <div class="card bg-base-200 border border-base-300 shadow-sm">
      <div class="card-body">
        <div class="stat-title text-base-content/60">Students</div>
        <div class="stat-value text-primary"><%= @report[:student_stats].size %></div>
        <div class="stat-desc text-base-content/55">Enrolled in class</div>
      </div>
    </div>
    <div class="card bg-base-200 border border-base-300 shadow-sm">
      <div class="card-body">
        <div class="stat-title text-base-content/60">Calendar days</div>
        <div class="stat-value text-primary"><%= (@report[:end_date] - @report[:start_date]).to_i + 1 %></div>
        <div class="stat-desc text-base-content/55">In selected range</div>
      </div>
    </div>
  </div>

  <% chart_rows = @report[:daily_totals].select { |d| d[:total].positive? } %>
  <% if chart_rows.any? %>
    <div class="card bg-base-200 border border-base-300 shadow-sm mb-6">
      <div class="card-body">
        <h2 class="card-title text-lg text-base-content mb-2">Daily present + late</h2>
        <p class="text-sm text-base-content/60 mb-4">Each bar is the count of students marked present or late that day.</p>
        <%= column_chart chart_rows.map { |d| [ d[:date].strftime("%b %d"), d[:attended] ] },
              colors: [ "#22c55e" ],
              height: "260px",
              library: { plugins: { legend: { display: false } } } %>
      </div>
    </div>
  <% elsif @report[:student_stats].any? %>
    <div class="alert alert-info mb-6">
      <span>No attendance saved in this date range yet. Use <strong>Mark today</strong> to record marks.</span>
    </div>
  <% end %>

  <div class="card bg-base-200 border border-base-300 shadow-sm">
    <div class="card-body">
      <h2 class="card-title text-lg text-base-content mb-4">Per-student summary</h2>
      <p class="text-sm text-base-content/60 mb-4">“%” is <strong>(present + late) ÷ days marked</strong> for each student.</p>
      <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
          <thead>
            <tr>
              <th class="text-base-content">Student</th>
              <th class="text-base-content">Present</th>
              <th class="text-base-content">Late</th>
              <th class="text-base-content">Absent</th>
              <th class="text-base-content">Excused</th>
              <th class="text-base-content">Days marked</th>
              <th class="text-base-content">%</th>
            </tr>
          </thead>
          <tbody>
            <% @report[:student_stats].each do |stat| %>
              <tr>
                <td>
                  <div class="font-medium text-base-content"><%= stat[:student].full_name %></div>
                  <div class="text-sm text-base-content/60"><%= stat[:student].admission_number %></div>
                </td>
                <td><span class="badge badge-success"><%= stat[:present_only] %></span></td>
                <td><span class="badge badge-warning badge-outline"><%= stat[:late_count] %></span></td>
                <td><span class="badge badge-error badge-outline"><%= stat[:absent_count] %></span></td>
                <td><span class="badge badge-info badge-outline"><%= stat[:excused_count] %></span></td>
                <td class="text-base-content/80"><%= stat[:total_days] %></td>
                <td>
                  <% if stat[:percentage].present? %>
                    <span class="font-medium text-base-content"><%= stat[:percentage] %>%</span>
                  <% else %>
                    <span class="text-base-content/50">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
