<% content_for :title, "Attendance Report - #{@classroom.name}" %>

<div>
  <div class="mb-6 flex justify-between items-center">
    <div>
      <div class="breadcrumbs text-sm mb-2">
        <ul>
          <li><%= link_to "Classrooms", classrooms_path, class: "text-blue-600 hover:text-blue-700" %></li>
          <li><%= link_to @classroom.name, classroom_path(@classroom), class: "text-blue-600 hover:text-blue-700" %></li>
          <li><%= link_to "Attendance", classroom_attendances_path(@classroom), class: "text-blue-600 hover:text-blue-700" %></li>
          <li>Reports</li>
        </ul>
      </div>
      <h1 class="text-3xl font-bold text-gray-900">Attendance Report</h1>
      <p class="text-gray-600 mt-1"><%= @classroom.name %> • <%= @start_date.strftime("%b %d, %Y") %> – <%= @end_date.strftime("%b %d, %Y") %></p>
    </div>
    <%= link_to classroom_attendances_path(@classroom), class: "btn btn-ghost" do %>
      Back to Attendance
    <% end %>
  </div>

  <%# Date range filter %>
  <%= form_with url: reports_classroom_attendances_path(@classroom), method: :get, local: true, class: "card bg-white shadow-md mb-6" do |f| %>
    <div class="card-body">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
        <div class="form-control">
          <label class="label">
            <span class="label-text text-gray-700">Start Date</span>
          </label>
          <%= f.date_field :start_date, value: @start_date, class: "input input-bordered" %>
        </div>
        <div class="form-control">
          <label class="label">
            <span class="label-text text-gray-700">End Date</span>
          </label>
          <%= f.date_field :end_date, value: @end_date, class: "input input-bordered" %>
        </div>
        <div>
          <%= f.submit "Update Report", class: "btn btn-primary" %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Summary stats %>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="card bg-white shadow-md">
      <div class="card-body">
        <div class="stat-title text-gray-600">Total Records</div>
        <div class="stat-value text-primary"><%= @report[:attendances].count %></div>
        <div class="stat-desc text-gray-600">Attendance entries in range</div>
      </div>
    </div>
    <div class="card bg-white shadow-md">
      <div class="card-body">
        <div class="stat-title text-gray-600">Students</div>
        <div class="stat-value text-primary"><%= @report[:student_stats].size %></div>
        <div class="stat-desc text-gray-600">In classroom</div>
      </div>
    </div>
    <div class="card bg-white shadow-md">
      <div class="card-body">
        <div class="stat-title text-gray-600">Days in Range</div>
        <div class="stat-value text-primary"><%= (@report[:end_date] - @report[:start_date]).to_i + 1 %></div>
        <div class="stat-desc text-gray-600">School days</div>
      </div>
    </div>
  </div>

  <%# Per-student stats %>
  <div class="card bg-white shadow-md">
    <div class="card-body">
      <h2 class="card-title text-xl text-gray-900 mb-4">Per-Student Summary</h2>
      <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
          <thead>
            <tr>
              <th class="text-gray-900">Student</th>
              <th class="text-gray-900">Present</th>
              <th class="text-gray-900">Absent</th>
              <th class="text-gray-900">Late</th>
              <th class="text-gray-900">Excused</th>
              <th class="text-gray-900">Total Days</th>
              <th class="text-gray-900">% Present</th>
            </tr>
          </thead>
          <tbody>
            <% @report[:student_stats].each do |stat| %>
              <tr>
                <td>
                  <div class="font-medium text-gray-900"><%= stat[:student].full_name %></div>
                  <div class="text-sm text-gray-600"><%= stat[:student].admission_number %></div>
                </td>
                <td><span class="badge badge-success"><%= stat[:present_count] %></span></td>
                <td><span class="badge badge-error"><%= stat[:absent_count] %></span></td>
                <td><span class="badge badge-warning"><%= stat[:late_count] %></span></td>
                <td><span class="badge badge-info"><%= stat[:excused_count] %></span></td>
                <td class="text-gray-700"><%= stat[:total_days] %></td>
                <td>
                  <% if stat[:percentage].present? %>
                    <span class="font-medium text-gray-900"><%= stat[:percentage] %>%</span>
                  <% else %>
                    <span class="text-gray-500">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
