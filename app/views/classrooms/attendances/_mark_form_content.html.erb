<%# locals: students, attendances_by_student %>
<div class="card bg-base-200 border border-base-300 shadow-sm">
  <div class="card-body">
    <div class="overflow-x-auto">
      <table class="table table-zebra w-full">
        <thead>
          <tr>
            <th class="text-base-content">Student</th>
            <th class="text-base-content">Admission #</th>
            <th class="text-base-content">Status</th>
            <th class="text-base-content">Remarks</th>
          </tr>
        </thead>
        <tbody>
          <% students.each_with_index do |student, idx| %>
            <% attendance = attendances_by_student[student.id] %>
            <tr>
              <td>
                <div class="font-medium text-base-content"><%= student.full_name %></div>
                <div class="text-sm text-base-content/60"><%= student.user.email_address %></div>
              </td>
              <td><span class="font-mono text-sm text-base-content/80"><%= student.admission_number %></span></td>
              <td>
                <div data-attendance-mark-target="row">
                  <%= hidden_field_tag "attendances[#{idx}][student_id]", student.id %>
                  <%= select_tag "attendances[#{idx}][status]",
                      options_for_select(
                        [["Present", "present"], ["Absent", "absent"], ["Late", "late"], ["Excused", "excused"]],
                        attendance&.status || "present"
                      ),
                      class: "select select-bordered select-sm w-full max-w-[9rem]",
                      data: { attendance_mark_target: "statusSelect" } %>
                </div>
              </td>
              <td>
                <%= text_field_tag "attendances[#{idx}][remarks]", attendance&.remarks, class: "input input-bordered input-sm w-full max-w-xs", placeholder: "Optional note" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if students.empty? %>
      <p class="text-center text-base-content/70 py-8">No students in this classroom.</p>
    <% else %>
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <%= submit_tag "Save attendance", class: "btn btn-primary" %>
        <span class="text-sm text-base-content/60">Saves everyone on this page for the selected date.</span>
      </div>
    <% end %>
  </div>
</div>
