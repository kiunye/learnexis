<div class="overflow-x-auto">
  <table class="table table-zebra w-full">
    <thead>
      <tr>
        <th class="text-base-content">Student</th>
        <th class="text-base-content">Admission #</th>
        <th class="text-base-content">Status</th>
        <th class="text-base-content">Remarks</th>
      </tr>
    </thead>
    <tbody>
      <% students.each do |student| %>
        <% attendance = attendances_by_student[student.id] %>
        <tr>
          <td>
            <div class="font-medium text-base-content"><%= student.full_name %></div>
            <div class="text-sm text-base-content/60"><%= student.user.email_address %></div>
          </td>
          <td><span class="font-mono text-sm text-base-content/80"><%= student.admission_number %></span></td>
          <td>
            <% if attendance %>
              <% case attendance.status %>
              <% when "present" %>
                <span class="badge badge-success">Present</span>
              <% when "absent" %>
                <span class="badge badge-error">Absent</span>
              <% when "late" %>
                <span class="badge badge-warning">Late</span>
              <% when "excused" %>
                <span class="badge badge-info">Excused</span>
              <% end %>
            <% else %>
              <span class="badge badge-ghost">Not marked</span>
            <% end %>
          </td>
          <td><span class="text-sm text-base-content/80"><%= attendance&.remarks.presence || "—" %></span></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
