<div class="overflow-x-auto">
  <table class="table table-zebra w-full">
    <thead>
      <tr>
        <th class="text-gray-900">Student</th>
        <th class="text-gray-900">Admission #</th>
        <th class="text-gray-900">Status</th>
        <th class="text-gray-900">Remarks</th>
      </tr>
    </thead>
    <tbody>
      <% students.each do |student| %>
        <% attendance = attendances_by_student[student.id] %>
        <tr>
          <td>
            <div class="font-medium text-gray-900"><%= student.full_name %></div>
            <div class="text-sm text-gray-600"><%= student.user.email_address %></div>
          </td>
          <td><span class="text-gray-700 font-mono text-sm"><%= student.admission_number %></span></td>
          <td>
            <% if attendance %>
              <% case attendance.status %>
              <% when "present" %>
                <span class="badge badge-success">Present</span>
              <% when "absent" %>
                <span class="badge badge-error">Absent</span>
              <% when "late" %>
                <span class="badge badge-warning">Late</span>
              <% when "excused" %>
                <span class="badge badge-info">Excused</span>
              <% end %>
            <% else %>
              <span class="text-gray-500">—</span>
            <% end %>
          </td>
          <td><span class="text-gray-700 text-sm"><%= attendance&.remarks %></span></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
