<tr>
  <td>
    <div class="font-medium text-gray-100"><%= classroom.name %></div>
    <div class="text-sm text-gray-600">Academic Year: <%= classroom.academic_year %></div>
  </td>
  <td>
    <span class="badge badge-outline text-gray-100">Grade <%= classroom.grade_level %></span>
  </td>
  <td>
    <% if classroom.class_teacher %>
      <div class="text-gray-300">
        <%= "#{classroom.class_teacher.first_name} #{classroom.class_teacher.last_name}" %>
      </div>
    <% else %>
      <span class="text-gray-600">Not assigned</span>
    <% end %>
  </td>
  <td>
    <span class="text-gray-300"><%= classroom.current_students_count %></span>
  </td>
  <td>
    <span class="text-gray-300"><%= classroom.capacity %></span>
  </td>
  <td>
    <% if classroom.full? %>
      <span class="badge badge-error">Full</span>
    <% elsif classroom.current_students_count >= (classroom.capacity * 0.9) %>
      <span class="badge badge-warning">Nearly Full</span>
    <% else %>
      <span class="badge badge-success">Available</span>
    <% end %>
  </td>
  <td>
    <span class="text-gray-300"><%= classroom.room_number || "—" %></span>
  </td>
  <td>
    <div class="flex gap-2">
      <%= link_to classroom_path(classroom), class: "btn btn-sm btn-ghost", data: { turbo_frame: "_top" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
      <% end %>
      <% if policy(classroom).update? %>
        <%= link_to edit_classroom_path(classroom), class: "btn btn-sm btn-ghost", data: { turbo_frame: "_top" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        <% end %>
      <% end %>
    </div>
  </td>
</tr>
