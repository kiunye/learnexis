<% content_for :title, "Classrooms" %>

<div>
  <%# Page Header %>
  <div class="mb-6 flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-bold text-gray-100">Classrooms</h1>
      <p class="text-gray-600 mt-1">Manage classrooms and student enrollment</p>
    </div>
    <% if policy(Classroom).create? %>
      <%= link_to new_classroom_path, class: "btn btn-primary" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New Classroom
      <% end %>
    <% end %>
  </div>

  <%# Search and Filters %>
  <%= turbo_frame_tag "classrooms_filters" do %>
    <div class="card bg-gray-800 border border-gray-700 shadow-md mb-6">
      <div class="card-body">
        <%= form_with url: classrooms_path, method: :get, local: false, data: { turbo_frame: "classrooms_list" }, class: "space-y-4" do |f| %>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <%# Search %>
            <div class="form-control">
              <label class="label">
                <span class="label-text text-gray-300">Search</span>
              </label>
              <%= f.text_field :search, 
                  value: params[:search], 
                  placeholder: "Name or room number...",
                  class: "input input-bordered w-full",
                  data: { controller: "search", action: "input->search#submit" } %>
            </div>

            <%# Academic Year Filter %>
            <div class="form-control">
              <label class="label">
                <span class="label-text text-gray-300">Academic Year</span>
              </label>
              <%= f.select :academic_year,
                  options_for_select([
                    [Date.current.year, Date.current.year],
                    [Date.current.year - 1, Date.current.year - 1],
                    [Date.current.year + 1, Date.current.year + 1]
                  ], params[:academic_year] || Date.current.year),
                  {},
                  { class: "select select-bordered w-full", data: { action: "change->search#submit" } } %>
            </div>

            <%# Grade Level Filter %>
            <div class="form-control">
              <label class="label">
                <span class="label-text text-gray-300">Grade Level</span>
              </label>
              <%= f.select :grade_level,
                  options_for_select([
                    ["All", ""],
                    ["Grade 1", 1],
                    ["Grade 2", 2],
                    ["Grade 3", 3],
                    ["Grade 4", 4],
                    ["Grade 5", 5],
                    ["Grade 6", 6],
                    ["Grade 7", 7],
                    ["Grade 8", 8]
                  ], params[:grade_level]),
                  {},
                  { class: "select select-bordered w-full", data: { action: "change->search#submit" } } %>
            </div>
          </div>

          <div class="flex gap-2">
            <%= f.submit "Filter", class: "btn btn-primary" %>
            <%= link_to "Clear", classrooms_path, class: "btn btn-ghost", data: { turbo_frame: "_top" } %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Classrooms Table %>
  <%= turbo_frame_tag "classrooms_list" do %>
    <div class="card bg-gray-800 border border-gray-700 shadow-md">
      <div class="card-body">
        <div class="overflow-x-auto">
          <table class="table table-zebra w-full">
            <thead>
              <tr>
                <th class="text-gray-100">Name</th>
                <th class="text-gray-100">Grade</th>
                <th class="text-gray-100">Teacher</th>
                <th class="text-gray-100">Students</th>
                <th class="text-gray-100">Capacity</th>
                <th class="text-gray-100">Status</th>
                <th class="text-gray-100">Room</th>
                <th class="text-gray-100">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if @classrooms.any? %>
                <%= render partial: "classroom_row", collection: @classrooms, as: :classroom %>
              <% else %>
                <tr>
                  <td colspan="8" class="text-center text-gray-300 py-8">
                    No classrooms found.
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <%# Pagination %>
        <% if @pagy && @pagy.pages > 1 %>
          <div class="mt-6 flex justify-center">
            <div class="join">
              <% if @pagy.prev %>
                <%= link_to "«", classrooms_path(page: @pagy.prev, search: params[:search], academic_year: params[:academic_year], grade_level: params[:grade_level]), class: "join-item btn" %>
              <% else %>
                <button class="join-item btn btn-disabled">«</button>
              <% end %>
              <% @pagy.series.each do |item| %>
                <% if item.is_a?(Integer) %>
                  <%= link_to item, classrooms_path(page: item, search: params[:search], academic_year: params[:academic_year], grade_level: params[:grade_level]), class: "join-item btn #{'btn-active' if item == @pagy.page}" %>
                <% elsif item == :gap %>
                  <button class="join-item btn btn-disabled">...</button>
                <% end %>
              <% end %>
              <% if @pagy.next %>
                <%= link_to "»", classrooms_path(page: @pagy.next, search: params[:search], academic_year: params[:academic_year], grade_level: params[:grade_level]), class: "join-item btn" %>
              <% else %>
                <button class="join-item btn btn-disabled">»</button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
