<%# Admin Summary Metrics %>
<%= turbo_frame_tag "widget_metrics_admin" do %>
  <div class="card bg-gray-800 border border-gray-700 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-lg font-bold text-white mb-4">Overview</h2>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-gray-300">Total Students</p>
          <p class="text-2xl font-bold text-white">0</p>
          <p class="text-xs text-gray-400 mt-1">
            <span class="text-green-400">+0%</span> from last month
          </p>
        </div>
        <div>
          <p class="text-sm text-gray-300">Total Classrooms</p>
          <p class="text-2xl font-bold text-white">0</p>
          <p class="text-xs text-gray-400 mt-1">
            <span class="text-gray-400">No change</span>
          </p>
        </div>
        <div>
          <p class="text-sm text-gray-300">Pending Fees</p>
          <p class="text-2xl font-bold text-white">$0</p>
          <p class="text-xs text-gray-400 mt-1">
            <span class="text-gray-400">0 invoices</span>
          </p>
        </div>
        <div>
          <p class="text-sm text-gray-300">Attendance Rate</p>
          <p class="text-2xl font-bold text-white">0%</p>
          <p class="text-xs text-gray-400 mt-1">
            <span class="text-gray-400">Today</span>
          </p>
        </div>
      </div>
    </div>
  </div>
<% end %>