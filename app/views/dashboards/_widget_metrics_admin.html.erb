<%# Admin Summary Metrics %>
<%= turbo_frame_tag "widget_metrics_admin" do %>
  <div class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="card-title text-lg font-bold text-base-content">Overview</h2>
          <p class="mt-1 text-xs text-base-content/60">Operational snapshot.</p>
        </div>
        <span class="badge badge-outline border-base-300 text-base-content/70">Admin</span>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-xs text-base-content/60">Total Students</p>
          <p class="mt-1 text-2xl font-bold text-base-content"><%= @dashboard_data[:total_students] %></p>
          <p class="mt-1 text-xs text-base-content/55">Active records</p>
        </div>
        <div>
          <p class="text-xs text-base-content/60">Total Classrooms</p>
          <p class="mt-1 text-2xl font-bold text-base-content"><%= @dashboard_data[:total_classrooms] %></p>
          <p class="mt-1 text-xs text-base-content/55">This academic year</p>
        </div>
        <div>
          <p class="text-xs text-base-content/60">Pending Fees</p>
          <p class="mt-1 text-2xl font-bold text-base-content"><%= number_to_currency(@dashboard_data[:pending_fees_amount]) %></p>
          <p class="mt-1 text-xs text-base-content/55"><%= @dashboard_data[:pending_invoices_count] %> invoices</p>
        </div>
        <div>
          <p class="text-xs text-base-content/60">Attendance Rate</p>
          <p class="mt-1 text-2xl font-bold text-base-content">
            <%= @dashboard_data[:attendance_rate].nil? ? "—" : "#{@dashboard_data[:attendance_rate]}%" %>
          </p>
          <p class="mt-1 text-xs text-base-content/55">
            <%= @dashboard_data[:attendance_total].zero? ? "No marks yet today" : "#{@dashboard_data[:attendance_present]} of #{@dashboard_data[:attendance_total]} present" %>
          </p>
        </div>
      </div>
      <div class="mt-5 flex flex-wrap gap-2">
        <%= link_to "Add student", new_student_path, class: "btn btn-sm btn-primary", data: { turbo_frame: "_top" } %>
        <%= link_to "Create invoice", new_invoice_path, class: "btn btn-sm btn-outline", data: { turbo_frame: "_top" } %>
        <%= link_to "Record payment", new_transaction_path, class: "btn btn-sm btn-outline", data: { turbo_frame: "_top" } %>
      </div>
    </div>
  </div>
<% end %>