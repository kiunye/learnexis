<%# Chart Card - Attendance Trends (Placeholder for Chartkick) %>
<%= turbo_frame_tag "widget_chart_attendance" do %>
  <div class="card bg-gray-800 border border-gray-700 shadow-md lg:col-span-2">
    <div class="card-body">
      <h2 class="card-title text-lg font-bold text-white mb-4">Attendance Trends</h2>
      <div class="h-64 bg-gray-700/50 rounded-lg flex items-center justify-center">
        <div class="text-center">
          <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
          </div>
        <div class="text-center">
          <p class="text-gray-400 text-sm">Chart will appear here</p>
          <p class="text-gray-500 text-xs mt-1">Install Chartkick to display attendance trends</p>
        </div>
      </div>
      <%# When Chartkick is installed, replace above with: %>
      <%#= line_chart attendance_data_path, height: "250px" %>
    </div>
  </div>
<% end %>