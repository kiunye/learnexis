<%# Distilled "needs attention" strip for fast scanning %>
<%= turbo_frame_tag "widget_attention" do %>
  <% pending_invoices = @dashboard_data[:pending_invoices_count].to_i %>
  <% attendance_total = @dashboard_data[:attendance_total].to_i %>

  <div class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="text-sm font-semibold text-base-content tracking-wide">Needs attention</h2>
          <p class="mt-1 text-xs text-base-content/60">A short list of what to do next.</p>
        </div>

        <div class="flex items-center gap-2">
          <span class="badge badge-outline border-base-300 text-base-content/70"><%= Current.user&.role&.humanize %></span>
        </div>
      </div>

      <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-3">
        <div class="rounded-xl border border-base-300 bg-base-200/50 px-4 py-3">
          <p class="text-xs text-base-content/60">Pending invoices</p>
          <p class="mt-1 text-lg font-semibold text-base-content"><%= pending_invoices %></p>
          <p class="mt-1 text-xs text-base-content/55">Includes overdue</p>
          <div class="mt-3">
            <%= link_to "Review invoices", invoices_path, class: "text-sm text-primary hover:opacity-80 font-medium", data: { turbo_frame: "_top" } %>
          </div>
        </div>

        <div class="rounded-xl border border-base-300 bg-base-200/50 px-4 py-3">
          <p class="text-xs text-base-content/60">Attendance today</p>
          <p class="mt-1 text-lg font-semibold text-base-content">
            <%= attendance_total.zero? ? "Not marked" : "Marked" %>
          </p>
          <p class="mt-1 text-xs text-base-content/55">
            <%= attendance_total.zero? ? "No classroom has submitted marks yet." : "#{@dashboard_data[:attendance_present]} of #{attendance_total} present." %>
          </p>
          <div class="mt-3">
            <%= link_to "Go to classrooms", classrooms_path, class: "text-sm text-primary hover:opacity-80 font-medium", data: { turbo_frame: "_top" } %>
          </div>
        </div>

        <div class="rounded-xl border border-base-300 bg-base-200/50 px-4 py-3">
          <p class="text-xs text-base-content/60">This month’s payments</p>
          <p class="mt-1 text-lg font-semibold text-base-content"><%= number_to_currency(@dashboard_data[:monthly_revenue]) %></p>
          <p class="mt-1 text-xs text-base-content/55">Payments recorded this month</p>
          <div class="mt-3">
            <%= link_to "Record payment", new_transaction_path, class: "text-sm text-primary hover:opacity-80 font-medium", data: { turbo_frame: "_top" } %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
