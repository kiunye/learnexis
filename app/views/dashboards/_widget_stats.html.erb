<%# DaisyUI Stats Component - Multi-metric Display %>
<%= turbo_frame_tag "widget_stats" do %>
  <div class="card bg-base-100 border border-base-300 shadow-sm lg:col-span-2">
    <div class="card-body">
      <h2 class="card-title text-lg font-bold text-base-content mb-4">Quick Stats</h2>
      <div class="stats stats-vertical lg:stats-horizontal shadow-sm w-full bg-base-200/60">
        <div class="stat">
          <div class="stat-figure text-primary">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <div class="stat-title text-base-content/60">Total Students</div>
          <div class="stat-value text-base-content"><%= @dashboard_data[:total_students] %></div>
          <div class="stat-desc text-base-content/55">Enrolled and active</div>
        </div>

        <div class="stat">
          <div class="stat-figure text-success">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="stat-title text-base-content/60">Attendance Today</div>
          <div class="stat-value text-base-content">
            <%= @dashboard_data[:attendance_rate].nil? ? "—" : "#{@dashboard_data[:attendance_rate]}%" %>
          </div>
          <div class="stat-desc text-base-content/55">
            <%= @dashboard_data[:attendance_total].zero? ? "No marks yet" : "#{@dashboard_data[:attendance_present]} present" %>
          </div>
        </div>

        <div class="stat">
          <div class="stat-figure text-warning">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="stat-title text-base-content/60">Monthly Revenue</div>
          <div class="stat-value text-base-content"><%= number_to_currency(@dashboard_data[:monthly_revenue]) %></div>
          <div class="stat-desc text-base-content/55">Payments this month</div>
        </div>
      </div>
    </div>
  </div>
<% end %>