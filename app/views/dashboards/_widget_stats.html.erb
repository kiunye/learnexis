<%# DaisyUI Stats Component - Multi-metric Display %>
<%= turbo_frame_tag "widget_stats" do %>
  <div class="card bg-gray-800 border border-gray-700 shadow-md lg:col-span-2">
    <div class="card-body">
      <h2 class="card-title text-lg font-bold text-gray-100 mb-4">Quick Stats</h2>
      <div class="stats stats-vertical lg:stats-horizontal shadow w-full">
        <div class="stat">
          <div class="stat-figure text-blue-400">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <div class="stat-title text-gray-400">Total Students</div>
          <div class="stat-value text-blue-400">0</div>
          <div class="stat-desc text-gray-500">All enrolled students</div>
        </div>

        <div class="stat">
          <div class="stat-figure text-green-400">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="stat-title text-gray-400">Attendance Today</div>
          <div class="stat-value text-green-400">0%</div>
          <div class="stat-desc text-gray-500">Present students</div>
        </div>

        <div class="stat">
          <div class="stat-figure text-orange-400">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="stat-title text-gray-400">Monthly Revenue</div>
          <div class="stat-value text-orange-400">$0</div>
          <div class="stat-desc text-gray-500">This month</div>
        </div>
      </div>
    </div>
  </div>
<% end %>
