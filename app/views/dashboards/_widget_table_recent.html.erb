<%# Table Card - Recent Transactions %>
<%= turbo_frame_tag "widget_table_recent" do %>
  <div class="card bg-base-100 border border-base-300 shadow-sm lg:col-span-2">
    <div class="card-body">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="card-title text-lg font-bold text-base-content">Recent Transactions</h2>
          <p class="mt-1 text-xs text-base-content/60">Latest payments and adjustments.</p>
        </div>
        <%= link_to "All", transactions_path, class: "btn btn-xs btn-outline", data: { turbo_frame: "_top" } %>
      </div>
      <div class="overflow-x-auto">
        <table class="table w-full">
          <thead>
            <tr class="border-base-300">
              <th class="text-base-content/70">Date</th>
              <th class="text-base-content/70">Student</th>
              <th class="text-base-content/70">Amount</th>
              <th class="text-base-content/70">Status</th>
              <th class="text-base-content/70">Method</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-base-300">
              <td colspan="5" class="text-center text-base-content/60 py-8">
                No transactions yet.
                <span class="block mt-2 text-sm text-base-content/55">Record a payment to start your ledger.</span>
                <span class="block mt-4">
                  <%= link_to "Record payment", new_transaction_path, class: "btn btn-sm btn-primary", data: { turbo_frame: "_top" } %>
                </span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="mt-4">
        <%= link_to "View all transactions →", transactions_path, class: "text-sm text-primary hover:opacity-80 font-medium", data: { turbo_frame: "_top" } %>
      </div>
    </div>
  </div>
<% end %>
