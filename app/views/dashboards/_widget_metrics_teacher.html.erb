<%# Teacher Summary Metrics %>
<%= turbo_frame_tag "widget_metrics_teacher" do %>
  <div class="card bg-gray-800 border border-gray-700 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-lg font-bold text-white mb-4">My Classes</h2>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-gray-300">My Students</p>
          <p class="text-2xl font-bold text-white">0</p>
          <p class="text-xs text-gray-400 mt-1">
            <span class="text-gray-400">Across all classes</span>
          </p>
        </div>
        <div>
          <p class="text-sm text-gray-300">Today's Attendance</p>
          <p class="text-2xl font-bold text-white">0%</p>
          <p class="text-xs text-gray-400 mt-1">
            <span class="text-gray-400">0 present</span>
          </p>
        </div>
        <div>
          <p class="text-sm text-gray-300">Pending Tasks</p>
          <p class="text-2xl font-bold text-white">0</p>
          <p class="text-xs text-gray-400 mt-1">
            <span class="text-gray-400">To complete</span>
          </p>
        </div>
        <div>
          <p class="text-sm text-gray-300">Upcoming Events</p>
          <p class="text-2xl font-bold text-white">0</p>
          <p class="text-xs text-gray-400 mt-1">
            <span class="text-gray-400">This week</span>
          </p>
        </div>
      </div>
    </div>
  </div>
<% end %>