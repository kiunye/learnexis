<%# Teacher Summary Metrics %>
<%= turbo_frame_tag "widget_metrics_teacher" do %>
  <div class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="card-title text-lg font-bold text-base-content">My Classes</h2>
          <p class="mt-1 text-xs text-base-content/60">Today’s teaching snapshot.</p>
        </div>
        <span class="badge badge-outline border-base-300 text-base-content/70">Teacher</span>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-xs text-base-content/60">My Students</p>
          <p class="mt-1 text-2xl font-bold text-base-content">0</p>
          <p class="mt-1 text-xs text-base-content/55">Across all classes</p>
        </div>
        <div>
          <p class="text-xs text-base-content/60">Today’s Attendance</p>
          <p class="mt-1 text-2xl font-bold text-base-content">0%</p>
          <p class="mt-1 text-xs text-base-content/55">0 present</p>
        </div>
        <div>
          <p class="text-xs text-base-content/60">Pending Tasks</p>
          <p class="mt-1 text-2xl font-bold text-base-content">0</p>
          <p class="mt-1 text-xs text-base-content/55">To complete</p>
        </div>
        <div>
          <p class="text-xs text-base-content/60">Upcoming Events</p>
          <p class="mt-1 text-2xl font-bold text-base-content">0</p>
          <p class="mt-1 text-xs text-base-content/55">This week</p>
        </div>
      </div>
      <div class="mt-5 flex flex-wrap gap-2">
        <%= link_to "Mark attendance", classrooms_path, class: "btn btn-sm btn-primary", data: { turbo_frame: "_top" } %>
        <%= link_to "View events", events_path, class: "btn btn-sm btn-outline", data: { turbo_frame: "_top" } %>
      </div>
    </div>
  </div>
<% end %>