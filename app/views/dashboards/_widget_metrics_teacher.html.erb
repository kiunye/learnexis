<%# Teacher Summary Metrics %>
<%= turbo_frame_tag "widget_metrics_teacher" do %>
  <div class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="card-title text-lg font-bold text-base-content">My classes</h2>
          <p class="mt-1 text-xs text-base-content/60">Today’s snapshot for your assigned classrooms.</p>
        </div>
        <span class="badge badge-outline border-base-300 text-base-content/70">Teacher</span>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-xs text-base-content/60">My students</p>
          <p class="mt-1 text-2xl font-bold text-base-content"><%= @dashboard_data[:total_students] %></p>
          <p class="mt-1 text-xs text-base-content/55">In your classrooms</p>
        </div>
        <div>
          <p class="text-xs text-base-content/60">Attendance today</p>
          <p class="mt-1 text-2xl font-bold text-base-content">
            <%= @dashboard_data[:attendance_rate].nil? ? "—" : "#{@dashboard_data[:attendance_rate]}%" %>
          </p>
          <p class="mt-1 text-xs text-base-content/55">
            <%= @dashboard_data[:attendance_total].zero? ? "Not marked yet" : "#{@dashboard_data[:attendance_present]} present / #{@dashboard_data[:attendance_total]} marked" %>
          </p>
        </div>
        <div>
          <p class="text-xs text-base-content/60">Classrooms</p>
          <p class="mt-1 text-2xl font-bold text-base-content"><%= @dashboard_data[:total_classrooms] %></p>
          <p class="mt-1 text-xs text-base-content/55">You teach</p>
        </div>
        <div>
          <p class="text-xs text-base-content/60">Pending fees (school)</p>
          <p class="mt-1 text-2xl font-bold text-base-content"><%= number_to_currency(@dashboard_data[:pending_fees_amount]) %></p>
          <p class="mt-1 text-xs text-base-content/55"><%= @dashboard_data[:pending_invoices_count] %> invoices</p>
        </div>
      </div>
      <div class="mt-5 flex flex-wrap gap-2">
        <%= link_to "Mark attendance", mark_attendance_quick_path, class: "btn btn-sm btn-primary", data: { turbo_frame: "_top" } %>
        <%= link_to "Classrooms", classrooms_path, class: "btn btn-sm btn-outline", data: { turbo_frame: "_top" } %>
        <%= link_to "Attendance report", attendance_reports_path, class: "btn btn-sm btn-outline", data: { turbo_frame: "_top" } %>
      </div>
    </div>
  </div>
<% end %>
