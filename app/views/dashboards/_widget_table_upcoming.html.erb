<%# Table Card - Upcoming Events %>
<%= turbo_frame_tag "widget_table_upcoming" do %>
  <div class="card bg-base-100 border border-base-300 shadow-sm lg:col-span-2">
    <div class="card-body">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="card-title text-lg font-bold text-base-content">Upcoming Events</h2>
          <p class="mt-1 text-xs text-base-content/60">School calendar highlights.</p>
        </div>
        <%= link_to "All", events_path, class: "btn btn-xs btn-outline", data: { turbo_frame: "_top" } %>
      </div>
      <div class="overflow-x-auto">
        <table class="table w-full">
          <thead>
            <tr class="border-base-300">
              <th class="text-base-content/70">Date</th>
              <th class="text-base-content/70">Event</th>
              <th class="text-base-content/70">Type</th>
              <th class="text-base-content/70">Status</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-base-300">
              <td colspan="4" class="text-center text-base-content/60 py-8">
                No upcoming events.
                <span class="block mt-2 text-sm text-base-content/55">Create an event to keep staff and parents aligned.</span>
                <span class="block mt-4">
                  <%= link_to "Create event", new_event_path, class: "btn btn-sm btn-primary", data: { turbo_frame: "_top" } %>
                </span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="mt-4">
        <%= link_to "View all events →", events_path, class: "text-sm text-primary hover:opacity-80 font-medium", data: { turbo_frame: "_top" } %>
      </div>
    </div>
  </div>
<% end %>
