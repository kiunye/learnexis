<%# Table Card - Upcoming Events %>
<%= turbo_frame_tag "widget_table_upcoming" do %>
  <div class="card bg-white shadow-md lg:col-span-2">
    <div class="card-body">
      <h2 class="card-title text-lg font-bold text-gray-900 mb-4">Upcoming Events</h2>
      <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
          <thead>
            <tr>
              <th>Date</th>
              <th>Event</th>
              <th>Type</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td colspan="4" class="text-center text-gray-500 py-8">
                No upcoming events. Events will appear here once they are created.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="mt-4">
        <a href="#" class="text-sm text-blue-600 hover:text-blue-700 font-medium">View all events →</a>
      </div>
    </div>
  </div>
<% end %>
