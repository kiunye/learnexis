<%# Table Card - Upcoming Events %>
<%= turbo_frame_tag "widget_table_upcoming" do %>
  <div class="card bg-gray-800 border border-gray-700 shadow-md lg:col-span-2">
    <div class="card-body">
      <h2 class="card-title text-lg font-bold text-gray-100 mb-4">Upcoming Events</h2>
      <div class="overflow-x-auto">
        <table class="table w-full">
          <thead>
            <tr class="border-gray-700">
              <th class="text-gray-300">Date</th>
              <th class="text-gray-300">Event</th>
              <th class="text-gray-300">Type</th>
              <th class="text-gray-300">Status</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-gray-700">
              <td colspan="4" class="text-center text-gray-500 py-8">
                No upcoming events. Events will appear here once they are created.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="mt-4">
        <a href="#" class="text-sm text-blue-400 hover:text-blue-300 font-medium">View all events →</a>
      </div>
    </div>
  </div>
<% end %>
