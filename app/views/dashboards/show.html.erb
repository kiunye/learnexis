<%# Subscribe to dashboard updates via Turbo Streams %>
<%= turbo_stream_from "dashboard:#{Current.user&.id}" %>

<div>
  <%# Page Header (distilled: greeting + primary actions + status) %>
  <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-base-content">Dashboard</h1>
      <p class="mt-1 text-base-content/70">
        Welcome back, <span class="text-base-content font-medium"><%= Current.user&.email_address&.split("@")&.first&.capitalize || "User" %></span>.
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      <% if Current.user&.admin? || Current.user&.teacher? %>
        <%= link_to "Add student", new_student_path, class: "btn btn-sm btn-primary" %>
        <%= link_to "Mark attendance", classrooms_path, class: "btn btn-sm btn-outline" %>
      <% end %>

      <% if Current.user&.admin? || Current.user&.teacher? || Current.user&.parent? %>
        <%= link_to "Create invoice", new_invoice_path, class: "btn btn-sm btn-outline" %>
        <%= link_to "Record payment", new_transaction_path, class: "btn btn-sm btn-outline" %>
      <% end %>

      <%= link_to "View notices", notices_path, class: "btn btn-sm btn-outline" %>
    </div>
  </div>

  <%# Needs attention (progressive disclosure: only what matters now) %>
  <%= render "dashboards/widget_attention" %>

  <%# Distilled grid: keep a few high-signal widgets; remove placeholders %>
  <div class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <%# Role-specific overview (now backed by real data for admin; others remain role widgets) %>
      <% if Current.user&.admin? %>
        <%= render "dashboards/widget_metrics_admin" %>
      <% elsif Current.user&.teacher? %>
        <%= render "dashboards/widget_metrics_teacher" %>
      <% elsif Current.user&.parent? %>
        <%= render "dashboards/widget_metrics_parent" %>
      <% else %>
        <%= render "dashboards/widget_metrics_student" %>
      <% end %>

      <%= render "dashboards/widget_table_recent" %>
    </div>

    <div class="space-y-6">
      <%= render "dashboards/widget_progress" %>
      <%= render "dashboards/widget_table_upcoming" %>
    </div>
  </div>
</div>
