<%# Subscribe to dashboard updates via Turbo Streams %>
<%= turbo_stream_from "dashboard:#{Current.user&.id}" %>

<div>
  <%# Page Header %>
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-100">Dashboard</h1>
    <p class="text-gray-400 mt-1">Welcome back, <%= Current.user&.email_address&.split("@")&.first&.capitalize || "User" %>!</p>
  </div>

  <%# Responsive Grid Layout: 3 columns desktop, 2 tablet, 1 mobile %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    
    <%# Summary Metric Cards - Role-specific %>
    <% if Current.user&.admin? %>
      <%= render "dashboards/widget_metrics_admin" %>
    <% elsif Current.user&.teacher? %>
      <%= render "dashboards/widget_metrics_teacher" %>
    <% elsif Current.user&.parent? %>
      <%= render "dashboards/widget_metrics_parent" %>
    <% else %>
      <%= render "dashboards/widget_metrics_student" %>
    <% end %>

    <%# Stats Component - Multi-metric Display %>
    <%= render "dashboards/widget_stats" %>

    <%# Progress Cards %>
    <%= render "dashboards/widget_progress" %>

    <%# List Cards with Icons %>
    <%= render "dashboards/widget_list" %>

    <%# Table Cards %>
    <%= render "dashboards/widget_table_recent" %>
    <%= render "dashboards/widget_table_upcoming" %>

    <%# Chart Cards (Placeholder - will use Chartkick when installed) %>
    <%= render "dashboards/widget_chart_attendance" %>
    <%= render "dashboards/widget_chart_financial" %>

  </div>
</div>
