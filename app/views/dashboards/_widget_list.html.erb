<%# List Cards with Icons/Flags %>
<%= turbo_frame_tag "widget_list" do %>
  <div class="card bg-gray-800 border border-gray-700 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-lg font-bold text-gray-100 mb-4">Top Classrooms</h2>
      <div class="space-y-3">
        <%# Placeholder list items - will be populated with real data %>
        <div class="flex items-center justify-between p-3 bg-gray-700/50 rounded-lg">
          <div class="flex items-center space-x-3">
            <div class="w-10 h-10 bg-blue-900/50 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-100">No classrooms yet</p>
              <p class="text-xs text-gray-500">Create classrooms to see attendance data</p>
            </div>
          </div>
          <div class="badge badge-success badge-sm">0%</div>
        </div>
      </div>
      <div class="mt-4">
        <a href="#" class="text-sm text-blue-400 hover:text-blue-300 font-medium">View all classrooms →</a>
      </div>
    </div>
  </div>
<% end %>
