<%# List Cards with Icons/Flags %>
<%= turbo_frame_tag "widget_list" do %>
  <div class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="card-title text-lg font-bold text-base-content">Top Classrooms</h2>
          <p class="mt-1 text-xs text-base-content/60">Attendance leaders (when data exists).</p>
        </div>
        <%= link_to "All", classrooms_path, class: "btn btn-xs btn-outline", data: { turbo_frame: "_top" } %>
      </div>
      <div class="space-y-3">
        <%# Placeholder list items - will be populated with real data %>
        <div class="flex items-center justify-between p-3 bg-base-200/60 rounded-xl border border-base-300">
          <div class="flex items-center space-x-3">
            <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-base-content">No classrooms yet</p>
              <p class="text-xs text-base-content/60">Create a classroom, then enroll students to unlock attendance tracking.</p>
            </div>
          </div>
          <div class="badge badge-outline border-base-300 text-base-content/70 badge-sm">—</div>
        </div>
      </div>
      <div class="mt-4">
        <div class="flex flex-wrap items-center gap-2">
          <%= link_to "Create classroom", new_classroom_path, class: "btn btn-sm btn-primary", data: { turbo_frame: "_top" } %>
          <%= link_to "View all classrooms →", classrooms_path, class: "text-sm text-primary hover:opacity-80 font-medium", data: { turbo_frame: "_top" } %>
        </div>
      </div>
    </div>
  </div>
<% end %>
