<%# Parent Summary Metrics %>
<%= turbo_frame_tag "widget_metrics_parent" do %>
  <div class="card bg-gray-800 border border-gray-700 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-lg font-bold text-white mb-4">My Children</h2>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-gray-300">Children</p>
          <p class="text-2xl font-bold text-white">0</p>
          <p class="text-xs text-gray-400 mt-1">
            <span class="text-gray-400">Enrolled</span>
          </p>
        </div>
        <div>
          <p class="text-sm text-gray-300">Outstanding Fees</p>
          <p class="text-2xl font-bold text-white">$0</p>
          <p class="text-xs text-gray-400 mt-1">
            <span class="text-gray-400">0 invoices</span>
          </p>
        </div>
        <div>
          <p class="text-sm text-gray-300">Attendance</p>
          <p class="text-2xl font-bold text-white">0%</p>
          <p class="text-xs text-gray-400 mt-1">
            <span class="text-gray-400">This month</span>
          </p>
        </div>
        <div>
          <p class="text-sm text-gray-300">Upcoming Events</p>
          <p class="text-2xl font-bold text-white">0</p>
          <p class="text-xs text-gray-400 mt-1">
            <span class="text-gray-400">This week</span>
          </p>
        </div>
      </div>
    </div>
  </div>
<% end %>