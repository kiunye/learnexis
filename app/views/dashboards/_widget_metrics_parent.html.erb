<%# Parent Summary Metrics %>
<%= turbo_frame_tag "widget_metrics_parent" do %>
  <div class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="card-title text-lg font-bold text-base-content">My Children</h2>
          <p class="mt-1 text-xs text-base-content/60">What changed since your last visit.</p>
        </div>
        <span class="badge badge-outline border-base-300 text-base-content/70">Parent</span>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-xs text-base-content/60">Children</p>
          <p class="mt-1 text-2xl font-bold text-base-content">0</p>
          <p class="mt-1 text-xs text-base-content/55">Enrolled</p>
        </div>
        <div>
          <p class="text-xs text-base-content/60">Outstanding Fees</p>
          <p class="mt-1 text-2xl font-bold text-base-content">$0</p>
          <p class="mt-1 text-xs text-base-content/55">0 invoices</p>
        </div>
        <div>
          <p class="text-xs text-base-content/60">Attendance</p>
          <p class="mt-1 text-2xl font-bold text-base-content">0%</p>
          <p class="mt-1 text-xs text-base-content/55">This month</p>
        </div>
        <div>
          <p class="text-xs text-base-content/60">Upcoming Events</p>
          <p class="mt-1 text-2xl font-bold text-base-content">0</p>
          <p class="mt-1 text-xs text-base-content/55">This week</p>
        </div>
      </div>
      <div class="mt-5 flex flex-wrap gap-2">
        <%= link_to "View invoices", invoices_path, class: "btn btn-sm btn-primary", data: { turbo_frame: "_top" } %>
        <%= link_to "View notices", notices_path, class: "btn btn-sm btn-outline", data: { turbo_frame: "_top" } %>
      </div>
    </div>
  </div>
<% end %>