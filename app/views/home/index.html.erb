<%# Academic Calendar Section %>
<section class="py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-gray-900 mb-12">ACADEMIC CALENDAR</h2>
    <div class="bg-white rounded-lg shadow-lg p-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <%# Month List %>
        <div class="lg:col-span-1">
          <h3 class="text-lg font-bold text-gray-900 mb-4">Select Month</h3>
          <ul class="space-y-2">
            <% %w[January February March April May June July August September October November December].each do |month| %>
              <li>
                <a href="#" class="block px-4 py-2 rounded-md <%= month == 'September' ? 'bg-red-600 text-white' : 'text-gray-700 hover:bg-gray-100' %> transition-colors">
                  <%= month %>
                </a>
              </li>
            <% end %>
          </ul>
        </div>

        <%# Calendar Grid %>
        <div class="lg:col-span-1">
          <div class="mb-4">
            <h3 class="text-xl font-bold text-gray-900">September 2025</h3>
          </div>
          <div class="grid grid-cols-7 gap-2">
            <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |day| %>
              <div class="text-center text-sm font-medium text-gray-600 py-2"><%= day %></div>
            <% end %>
            <% (1..30).each do |day| %>
              <div class="text-center py-2 <%= [1, 5, 8, 15, 20, 25].include?(day) ? 'relative' : '' %>">
                <span class="<%= [1, 5, 8, 15, 20, 25].include?(day) ? 'text-gray-900 font-medium' : 'text-gray-600' %>">
                  <%= day %>
                </span>
                <% if [1, 5, 8, 15, 20, 25].include?(day) %>
                  <span class="absolute bottom-0 left-1/2 transform -translate-x-1/2 w-1 h-1 bg-red-600 rounded-full"></span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <%# Events List %>
        <div class="lg:col-span-1">
          <h3 class="text-lg font-bold text-gray-900 mb-4">Upcoming Events</h3>
          <ul class="space-y-3">
            <li class="flex items-start">
              <span class="w-2 h-2 bg-red-600 rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <div>
                <p class="text-sm font-medium text-gray-900">First Installment Fees Due</p>
                <p class="text-xs text-gray-500">September 1, 2025</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="w-2 h-2 bg-red-600 rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <div>
                <p class="text-sm font-medium text-gray-900">First Day of School: G1-12</p>
                <p class="text-xs text-gray-500">September 5, 2025</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="w-2 h-2 bg-red-600 rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <div>
                <p class="text-sm font-medium text-gray-900">First Day of School: K-2</p>
                <p class="text-xs text-gray-500">September 8, 2025</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="w-2 h-2 bg-red-600 rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <div>
                <p class="text-sm font-medium text-gray-900">KG Extended Day Program Begins</p>
                <p class="text-xs text-gray-500">September 15, 2025</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="w-2 h-2 bg-red-600 rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <div>
                <p class="text-sm font-medium text-gray-900">Parent Open House</p>
                <p class="text-xs text-gray-500">September 20, 2025</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="w-2 h-2 bg-red-600 rounded-full mt-2 mr-3 flex-shrink-0"></span>
              <div>
                <p class="text-sm font-medium text-gray-900">Phonological Assessments</p>
                <p class="text-xs text-gray-500">September 25, 2025</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

