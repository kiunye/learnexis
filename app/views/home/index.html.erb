<% content_for :title, "LearnExis - Bringing Talent to Life" %>

<%# Navigation Bar %>
<nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <%# Logo %>
      <div class="flex items-center">
        <%= link_to root_path, class: "flex items-center space-x-2" do %>
          <div class="w-10 h-10 bg-red-600 rounded-md flex items-center justify-center">
            <span class="text-white font-bold text-xl">L</span>
          </div>
          <span class="text-xl font-bold text-gray-900">LEARNEXIS</span>
        <% end %>
      </div>

      <%# Navigation Links %>
      <div class="hidden md:flex md:space-x-8">
        <a href="#home" class="text-gray-900 hover:text-red-600 text-sm font-medium transition-colors">HOME</a>
        <a href="#about" class="text-gray-900 hover:text-red-600 text-sm font-medium transition-colors">ABOUT US</a>
        <a href="#academics" class="text-gray-900 hover:text-red-600 text-sm font-medium transition-colors">ACADEMICS</a>
        <a href="#admission" class="text-gray-900 hover:text-red-600 text-sm font-medium transition-colors">ADMISSION</a>
        <a href="#community" class="text-gray-900 hover:text-red-600 text-sm font-medium transition-colors">COMMUNITY</a>
        <a href="#careers" class="text-gray-900 hover:text-red-600 text-sm font-medium transition-colors">CAREERS</a>
      </div>

      <%# Log In Button %>
      <div class="flex items-center">
        <%= link_to new_session_path, class: "px-4 py-2 bg-red-600 text-white rounded-md text-sm font-medium hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors" do %>
          LOG IN
        <% end %>
      </div>
    </div>
  </div>
</nav>

<%# Hero Section %>
<section id="home" class="relative bg-gray-900 text-white py-20 lg:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-lg text-red-400 mb-2 uppercase tracking-wide">Bringing Talent to Life</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          LEARNEXIS SCHOOL MANAGEMENT SYSTEM
        </h1>
        <p class="text-xl text-gray-300 mb-8">
          Empowering students to reach their full potential through excellence in education.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <%= link_to "#admission", class: "px-6 py-3 bg-red-600 text-white rounded-md font-medium hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors text-center" do %>
            ENQUIRE NOW
          <% end %>
          <%= link_to "#about", class: "px-6 py-3 border-2 border-red-600 text-red-600 rounded-md font-medium hover:bg-red-600 hover:text-white transition-colors text-center" do %>
            ABOUT US
          <% end %>
        </div>
      </div>
      <div class="hidden lg:block">
        <div class="bg-gray-800 rounded-lg p-8 aspect-video flex items-center justify-center">
          <p class="text-gray-400 text-center">Hero Image Placeholder<br/><span class="text-sm">Students in school uniforms</span></p>
        </div>
      </div>
    </div>
  </div>
</section>

<%# Welcome Section %>
<section id="about" class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          WELCOME TO <span class="text-red-600">LEARNEXIS</span>
        </h2>
        <p class="text-lg text-gray-700 mb-4">
          LearnExis is a comprehensive school management system designed to streamline operations, enhance communication, and support the educational journey of every student.
        </p>
        <p class="text-lg text-gray-700 mb-4">
          Our platform brings together students, parents, teachers, and administrators in a seamless digital environment that fosters collaboration and excellence.
        </p>
        <p class="text-lg text-gray-700">
          From attendance tracking to fee management, from academic records to event coordination, LearnExis provides all the tools your school needs to thrive.
        </p>
      </div>
      <div class="bg-gray-100 rounded-lg p-8 aspect-square flex items-center justify-center">
        <p class="text-gray-400 text-center">Welcome Image Placeholder<br/><span class="text-sm">Educational content image</span></p>
      </div>
    </div>
  </div>
</section>

