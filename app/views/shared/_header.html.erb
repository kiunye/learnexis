<%# Top header bar - sticky header with search, greeting, and user menu %>
<header class="sticky top-0 z-20 bg-base-100/90 backdrop-blur border-b border-base-300">
  <div class="flex items-center justify-between h-16 px-4 lg:px-6">
    <%# Left side: Mobile menu toggle + Search %>
    <div class="flex items-center space-x-4 flex-1">
      <%# Mobile menu toggle (hidden on desktop) %>
      <label for="drawer-toggle" class="drawer-button lg:hidden btn btn-ghost btn-sm btn-square text-base-content/70 hover:text-base-content focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary/30 focus-visible:ring-offset-base-100">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <span class="sr-only">Open menu</span>
      </label>

      <%# Global search %>
      <div class="hidden md:flex flex-1 max-w-md">
        <%= form_with url: search_path, method: :get, local: true, class: "relative w-full" do %>
          <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
            <svg class="w-5 h-5 text-base-content/45" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <%= search_field_tag :query, params[:query], placeholder: "Search students, invoices, events…", class: "block w-full pl-10 pr-3 py-2 border border-base-300 rounded-lg leading-5 bg-base-100 text-base-content placeholder:text-base-content/45 focus:outline-none focus:ring-4 focus:ring-primary/15 focus:border-primary/40 sm:text-sm" %>
        <% end %>
      </div>
    </div>

    <%# Right side: Greeting + User menu %>
    <div class="flex items-center space-x-4">
      <%# Personalized greeting (hidden on mobile) %>
      <div class="hidden lg:block">
        <p class="text-sm text-base-content/70">
          Welcome back, <span class="font-medium text-base-content"><%= Current.user&.email_address&.split("@")&.first&.capitalize || "User" %></span>
        </p>
      </div>

      <%# User menu dropdown %>
      <div class="dropdown dropdown-end">
        <label tabindex="0" class="btn btn-ghost btn-circle avatar focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary/20 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100">
          <div class="w-10 rounded-full bg-primary text-primary-content flex items-center justify-center">
            <span class="text-sm font-medium">
              <%= Current.user&.email_address&.first&.upcase || "U" %>
            </span>
          </div>
        </label>
        <ul tabindex="0" 
            class="dropdown-content menu bg-base-100 rounded-xl shadow-lg border border-base-300 w-52 mt-2 z-50">
          <li class="px-4 py-2 border-b border-base-300">
            <div class="flex flex-col">
              <span class="text-sm font-medium text-base-content"><%= Current.user&.email_address || "User" %></span>
              <span class="text-xs text-base-content/55 capitalize"><%= Current.user&.role&.humanize || "Role" %></span>
            </div>
          </li>
          <li class="border-t border-base-300">
            <%= button_to session_path, method: :delete, 
                class: "w-full flex items-center space-x-2 px-4 py-2 text-sm text-error hover:bg-error/10 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-error/15 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100",
                form: { class: "w-full" } do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 013-3V7a3 3 0 013-3h4a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
              <span>Sign Out</span>
            <% end %>
          </li>
        </ul>
      </div>
    </div>
  </div>
</header>