<%# Sidebar navigation - pinned left sidebar for authenticated app interface %>
<aside class="drawer-side z-30">
  <label for="drawer-toggle" class="drawer-overlay bg-black/50"></label>
  <div class="w-64 min-h-full bg-base-100 border-r border-base-300 flex flex-col">
    <%# Logo/Branding Section %>
    <div class="h-16 flex items-center px-6 border-b border-base-300">
      <%= link_to dashboard_path, class: "flex items-center space-x-2" do %>
        <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center shadow-sm">
          <span class="text-primary-content font-bold text-lg">L</span>
        </div>
        <span class="text-xl font-bold text-base-content tracking-tight">LearnExis</span>
      <% end %>
    </div>

    <%# User Profile Section %>
    <div class="px-6 py-4 border-b border-base-300">
      <div class="flex items-center space-x-3">
        <div class="avatar placeholder">
          <div class="bg-primary text-primary-content rounded-full w-10 h-10 flex items-center justify-center">
            <span class="text-sm font-medium">
              <%= Current.user&.email_address&.first&.upcase || "U" %>
            </span>
          </div>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-base-content truncate">
            <%= Current.user&.email_address || "User" %>
          </p>
          <p class="text-xs text-base-content/60 capitalize">
            <%= Current.user&.role&.humanize || "Role" %>
          </p>
        </div>
      </div>
    </div>

    <%# Primary Navigation Menu %>
    <nav class="flex-1 overflow-y-auto px-4 py-4">
      <ul class="space-y-1">
        <%# Dashboard - always visible %>
        <li>
          <%= link_to dashboard_path, 
              class: "flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary/15 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100 #{'bg-primary/10 text-primary' if current_page?(dashboard_path)} #{'text-base-content/70 hover:bg-base-200 hover:text-base-content' unless current_page?(dashboard_path)}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span>Dashboard</span>
          <% end %>
        </li>

        <%# Role-based navigation items (placeholders for future features) %>
        <% if Current.user&.admin? || Current.user&.teacher? %>
          <li>
            <%= link_to students_path, class: "flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary/15 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100 #{'bg-primary/10 text-primary' if current_page?(students_path)} #{'text-base-content/70 hover:bg-base-200 hover:text-base-content' unless current_page?(students_path)}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
              <span>Students</span>
            <% end %>
          </li>
          <li>
            <%= link_to classrooms_path, class: "flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary/15 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100 #{'bg-primary/10 text-primary' if current_page?(classrooms_path)} #{'text-base-content/70 hover:bg-base-200 hover:text-base-content' unless current_page?(classrooms_path)}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2-2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              <span>Classrooms</span>
            <% end %>
          </li>
        <% end %>

        <% if Current.user&.admin? || Current.user&.teacher? || Current.user&.parent? %>
          <li>
            <%= link_to invoices_path, class: "flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary/15 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100 #{'bg-primary/10 text-primary' if current_page?(invoices_path)} #{'text-base-content/70 hover:bg-base-200 hover:text-base-content' unless current_page?(invoices_path)}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <span>Invoices</span>
            <% end %>
          </li>
          <li>
            <%= link_to fees_path, class: "flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary/15 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100 #{'bg-primary/10 text-primary' if current_page?(fees_path)} #{'text-base-content/70 hover:bg-base-200 hover:text-base-content' unless current_page?(fees_path)}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>Fees</span>
            <% end %>
          </li>
          <li>
            <%= link_to transactions_path, class: "flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary/15 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100 #{'bg-primary/10 text-primary' if current_page?(transactions_path)} #{'text-base-content/70 hover:bg-base-200 hover:text-base-content' unless current_page?(transactions_path)}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2-2v6a2 2 0 002 2h2m6 0h2a2 2 0 002-2v-6a2 2 0 00-2-2h-2m-6 0H9a2 2 0 00-2 2v6a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
              <span>Transactions</span>
            <% end %>
          </li>
        <% end %>

        <% if Current.user&.admin? || Current.user&.teacher? %>
          <li>
            <%= link_to classrooms_path, class: "flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary/15 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100 text-base-content/70 hover:bg-base-200 hover:text-base-content" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
              </svg>
              <span>Attendance</span>
            <% end %>
          </li>
          <li>
            <%= link_to events_path, class: "flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary/15 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100 #{'bg-primary/10 text-primary' if current_page?(events_path)} #{'text-base-content/70 hover:bg-base-200 hover:text-base-content' unless current_page?(events_path)}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v12a2 2 0 002 2z" />
              </svg>
              <span>Events</span>
            <% end %>
          </li>
          <li>
            <%= link_to notices_path, class: "flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary/15 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100 #{'bg-primary/10 text-primary' if current_page?(notices_path)} #{'text-base-content/70 hover:bg-base-200 hover:text-base-content' unless current_page?(notices_path)}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
              </svg>
              <span>Notices</span>
            <% end %>
          </li>
        <% end %>

        <% if Current.user&.admin? %>
          <li>
            <%= link_to financial_reports_path, class: "flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary/15 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100 #{'bg-primary/10 text-primary' if current_page?(financial_reports_path)} #{'text-base-content/70 hover:bg-base-200 hover:text-base-content' unless current_page?(financial_reports_path)}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2-2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
              <span>Reports</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </nav>

    <%# Secondary Navigation (keep only real destinations) %>
    <div class="border-t border-base-300 px-4 py-4 space-y-1">
      <%= button_to session_path, method: :delete, 
          class: "w-full flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium text-error hover:bg-error/10 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-error/15 focus-visible:ring-offset-2 focus-visible:ring-offset-base-100",
          form: { class: "w-full" } do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 013-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
        <span>Sign Out</span>
      <% end %>
    </div>
  </div>
</aside>