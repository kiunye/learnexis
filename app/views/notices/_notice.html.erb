<div data-notice-id="<%= notice.id %>" class="card bg-base-100 shadow-xl mb-4">
  <div class="card-body">
    <div class="flex justify-between items-start mb-2">
      <h3 class="card-title text-lg font-semibold"><%= notice.title %></h3>
      <div class="flex items-center space-x-2">
        <%= badge_tag notice.priority.titleize, 
                      variant: notice.priority.to_sym == :urgent ? "error" : 
                              notice.priority.to_sym == :normal ? "warning" : "secondary",
                      class: "badge" %>
        <%= badge_tag notice.notice_type.titleize, variant: "info", class: "badge" %>
      </div>
    </div>
    
    <p class="text-preline mb-4"><%= truncate(notice.content, length: 150) %></p>
    
    <div class="flex justify-between items-center text-sm text-muted-foreground">
      <div>
        <span>By: <%= notice.author&.full_name || "Unknown" %></span>
        <span class="mx-2">•</span>
        <span><%= l(notice.published_at, format: :short) if notice.published_at %></span>
      </div>
      
      <% if notice.expires_at? %>
        <span class="badge <%= notice.expires_at.past? ? "badge-error" : "badge-outline" %>">
          <%= l(notice.expires_at, format: :short) %>
        </span>
      <% end %>
    </div>
    
    <div class="card-actions justify-end mt-4">
      <% if policy(notice).show? %>
        <%= link_to "Details", notice_path(notice), class: "btn btn-sm btn-outline" %>
      <% end %>
      
      <% if policy(notice).update? %>
        <%= link_to "Edit", edit_notice_path(notice), class: "btn btn-sm btn-outline" %>
      <% end %>
      
      <% if policy(notice).destroy? %>
        <%= button_to "Delete", notice_path(notice), 
                      method: :delete,
                      data: { turbo_confirm: "Are you sure you want to delete this notice?" },
                      class: "btn btn-sm btn-error" %>
      <% end %>
    </div>
  </div>
</div>