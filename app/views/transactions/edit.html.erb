<% content_for :title, "Edit Transaction ##{@transaction.id}" %>

<div>
  <div class="mb-6">
    <div class="breadcrumbs text-sm mb-2">
      <ul>
        <li><%= link_to "Transactions", transactions_path, class: "text-blue-600 hover:text-blue-700" %></li>
        <li><%= link_to "##{@transaction.id}", transaction_path(@transaction), class: "text-blue-600 hover:text-blue-700" %></li>
        <li>Edit</li>
      </ul>
    </div>
    <h1 class="text-3xl font-bold text-gray-100">Edit Transaction</h1>
    <p class="text-gray-600 mt-1">Transaction #<%= @transaction.id %> – <%= number_to_currency(@transaction.amount) %></p>
  </div>

  <%= render "form", transaction: @transaction %>
</div>
