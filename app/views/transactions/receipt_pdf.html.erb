<%# Receipt PDF – rendered to HTML then converted to PDF by Grover. %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Receipt #<%= @transaction.id %></title>
  <style>
    * { box-sizing: border-box; }
    body { font-family: system-ui, sans-serif; font-size: 11px; color: #000; margin: 0; padding: 0; line-height: 1.5; }
    .receipt-title { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
    .brand { font-size: 10px; color: #666; margin-bottom: 16px; }
    .block { margin-bottom: 8px; }
    .label { color: #666; font-size: 10px; }
    .amount { font-size: 14px; font-weight: 700; margin: 4px 0; }
    .thanks { margin-top: 12px; font-size: 10px; color: #666; }
  </style>
</head>
<body>
  <div class="receipt-title">RECEIPT</div>
  <div class="brand">Learnexis</div>

  <div class="block">
    <strong>Receipt #<%= @transaction.id %></strong>
  </div>
  <div class="block">Date: <%= @transaction.transaction_date.strftime('%d %b %Y') %></div>
  <div class="block">Student: <%= @transaction.student.full_name %></div>
  <div class="block label">Admission: <%= @transaction.student.admission_number %></div>

  <% if @transaction.invoice_id.present? %>
    <div class="block">Invoice: #<%= @transaction.invoice_id %></div>
  <% end %>

  <div class="block amount">Amount: <%= number_to_currency(@transaction.amount) %></div>
  <div class="block">Payment method: <%= @transaction.payment_method.humanize %></div>
  <div class="block">Type: <%= @transaction.transaction_type.humanize %></div>
  <div class="block">Reference: <%= @transaction.reference.presence || '—' %></div>
  <% if @transaction.notes.present? %>
    <div class="block"><%= @transaction.notes %></div>
  <% end %>

  <div class="thanks">Thank you for your payment.</div>
</body>
</html>
