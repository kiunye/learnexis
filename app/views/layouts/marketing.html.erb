<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "LearnExis - School Management System" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="LearnExis - Bringing Talent to Life. Modern school management system for educational institutions.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Lexend Deca font from Google Fonts %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lexend+Deca:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="font-sans bg-gray-950 text-gray-100" style="font-family: 'Lexend Deca', ui-sans-serif, system-ui, sans-serif;">
    <%= yield %>

    <%# Flash messages for marketing pages %>
    <%= render "shared/flash_messages" %>
  </body>
</html>
