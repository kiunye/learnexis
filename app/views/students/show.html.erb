<% content_for :title, @student.full_name %>

<div>
  <%# Page Header %>
  <div class="mb-6 flex justify-between items-center">
    <div>
      <div class="breadcrumbs text-sm mb-2">
        <ul>
          <li><%= link_to "Students", students_path, class: "text-blue-600 hover:text-blue-700" %></li>
          <li><%= @student.full_name %></li>
        </ul>
      </div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @student.full_name %></h1>
      <p class="text-gray-600 mt-1">Admission #<%= @student.admission_number %></p>
    </div>
    <div class="flex gap-2">
      <% if policy(@student).update? %>
        <%= link_to edit_student_path(@student), class: "btn btn-primary" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          Edit
        <% end %>
      <% end %>
      <%= link_to students_path, class: "btn btn-ghost" do %>
        Back to List
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Main Info Card %>
    <div class="lg:col-span-2 space-y-6">
      <%# Personal Information %>
      <div class="card bg-white shadow-md">
        <div class="card-body">
          <h2 class="card-title text-xl mb-4 text-gray-900">Personal Information</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="label">
                <span class="label-text font-medium text-gray-700">Full Name</span>
              </label>
              <p class="text-gray-700"><%= @student.full_name %></p>
            </div>
            <div>
              <label class="label">
                <span class="label-text font-medium text-gray-700">Email</span>
              </label>
              <p class="text-gray-700"><%= @student.user.email_address %></p>
            </div>
            <div>
              <label class="label">
                <span class="label-text font-medium text-gray-700">Phone Number</span>
              </label>
              <p class="text-gray-700"><%= @student.user.phone_number || "—" %></p>
            </div>
            <div>
              <label class="label">
                <span class="label-text font-medium text-gray-700">Date of Birth</span>
              </label>
              <p class="text-gray-700"><%= @student.date_of_birth&.strftime("%B %d, %Y") || "—" %></p>
            </div>
            <div>
              <label class="label">
                <span class="label-text font-medium text-gray-700">Blood Group</span>
              </label>
              <p class="text-gray-700"><%= @student.blood_group || "—" %></p>
            </div>
            <div>
              <label class="label">
                <span class="label-text font-medium text-gray-700">Status</span>
              </label>
              <p>
                <% case @student.status %>
                <% when "active" %>
                  <span class="badge badge-success">Active</span>
                <% when "inactive" %>
                  <span class="badge badge-error">Inactive</span>
                <% when "graduated" %>
                  <span class="badge badge-info">Graduated</span>
                <% when "transferred" %>
                  <span class="badge badge-warning">Transferred</span>
                <% end %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <%# Academic Information %>
      <div class="card bg-white shadow-md">
        <div class="card-body">
          <h2 class="card-title text-xl mb-4 text-gray-900">Academic Information</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="label">
                <span class="label-text font-medium text-gray-700">Classroom</span>
              </label>
              <p class="text-gray-700">
                <% if @student.classroom %>
                  <span class="badge badge-outline text-gray-900"><%= @student.classroom.name %></span>
                <% else %>
                  <span class="text-gray-600">Not assigned</span>
                <% end %>
              </p>
            </div>
            <div>
              <label class="label">
                <span class="label-text font-medium text-gray-700">Admission Date</span>
              </label>
              <p class="text-gray-700"><%= @student.admission_date&.strftime("%B %d, %Y") || "—" %></p>
            </div>
          </div>
        </div>
      </div>

      <%# Medical & Special Needs %>
      <% if @student.medical_conditions.present? || @student.allergies.present? || @student.special_needs.present? %>
        <div class="card bg-white shadow-md">
          <div class="card-body">
            <h2 class="card-title text-xl mb-4 text-gray-900">Medical & Special Needs</h2>
            <div class="space-y-4">
              <% if @student.medical_conditions.present? %>
                <div>
                    <label class="label">
                      <span class="label-text font-medium text-gray-700">Medical Conditions</span>
                    </label>
                  <p class="text-gray-700"><%= @student.medical_conditions %></p>
                </div>
              <% end %>
              <% if @student.allergies.present? %>
                <div>
                    <label class="label">
                      <span class="label-text font-medium text-gray-700">Allergies</span>
                    </label>
                  <p class="text-gray-700"><%= @student.allergies %></p>
                </div>
              <% end %>
              <% if @student.special_needs.present? %>
                <div>
                    <label class="label">
                      <span class="label-text font-medium text-gray-700">Special Needs</span>
                    </label>
                  <p class="text-gray-700"><%= @student.special_needs %></p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <%# Emergency Contact %>
      <div class="card bg-white shadow-md">
        <div class="card-body">
          <h2 class="card-title text-xl mb-4 text-gray-900">Emergency Contact</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="label">
                <span class="label-text font-medium text-gray-700">Contact Name</span>
              </label>
              <p class="text-gray-700"><%= @student.emergency_contact_name || "—" %></p>
            </div>
            <div>
              <label class="label">
                <span class="label-text font-medium text-gray-700">Contact Phone</span>
              </label>
              <p class="text-gray-700"><%= @student.emergency_contact_phone || "—" %></p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# Sidebar %>
    <div class="space-y-6">
      <%# Photo Card %>
      <div class="card bg-white shadow-md">
        <div class="card-body">
          <h2 class="card-title text-lg mb-4 text-gray-900">Photo</h2>
          <div class="flex justify-center">
            <% if @student.photo.attached? %>
              <%= image_tag @student.photo, class: "w-48 h-48 rounded-lg object-cover" %>
            <% else %>
              <div class="w-48 h-48 rounded-lg bg-gray-200 flex items-center justify-center">
                <span class="text-gray-600">No photo</span>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <%# Parents Card %>
      <% if @student.parents.any? %>
        <div class="card bg-white shadow-md">
          <div class="card-body">
            <h2 class="card-title text-lg mb-4 text-gray-900">Parents/Guardians</h2>
            <div class="space-y-3">
              <% @student.parents.each do |parent| %>
                <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg">
                  <div class="flex-1">
                    <p class="font-medium text-gray-900"><%= "#{parent.first_name} #{parent.last_name}" %></p>
                    <p class="text-sm text-gray-600"><%= parent.email_address %></p>
                    <% if parent.phone_number.present? %>
                      <p class="text-sm text-gray-600"><%= parent.phone_number %></p>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
