<tr>
  <td>
    <span class="font-mono text-sm text-gray-100"><%= student.admission_number %></span>
  </td>
  <td>
    <div class="flex items-center gap-3">
      <% if student.photo.attached? %>
        <%= image_tag student.photo, class: "w-10 h-10 rounded-full object-cover" %>
      <% else %>
        <div class="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center">
          <span class="text-gray-300 text-sm font-medium"><%= student.user.first_name&.first&.upcase || "?" %></span>
        </div>
      <% end %>
      <div>
        <div class="font-medium text-gray-100"><%= student.full_name %></div>
        <div class="text-sm text-gray-600"><%= student.user.email_address %></div>
      </div>
    </div>
  </td>
  <td>
    <% if student.classroom %>
      <span class="badge badge-outline text-gray-100"><%= student.classroom.name %></span>
    <% else %>
      <span class="text-gray-600">Not assigned</span>
    <% end %>
  </td>
  <td>
    <% case student.status %>
    <% when "active" %>
      <span class="badge badge-success">Active</span>
    <% when "inactive" %>
      <span class="badge badge-error">Inactive</span>
    <% when "graduated" %>
      <span class="badge badge-info">Graduated</span>
    <% when "transferred" %>
      <span class="badge badge-warning">Transferred</span>
    <% end %>
  </td>
  <td>
    <span class="text-gray-300"><%= student.admission_date&.strftime("%b %d, %Y") || "—" %></span>
  </td>
  <td>
    <div class="flex gap-2">
      <%= link_to student_path(student), class: "btn btn-sm btn-ghost" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
      <% end %>
      <% if policy(student).update? %>
        <%= link_to edit_student_path(student), class: "btn btn-sm btn-ghost" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        <% end %>
      <% end %>
      <% if policy(student).destroy? %>
        <%= link_to student_path(student), 
            method: :delete,
            data: { 
              turbo_method: :delete,
              turbo_confirm: "Are you sure you want to deactivate this student?",
              controller: "modal",
              action: "click->modal#confirm"
            },
            class: "btn btn-sm btn-ghost text-error" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        <% end %>
      <% end %>
    </div>
  </td>
</tr>
