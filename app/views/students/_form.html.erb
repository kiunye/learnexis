<%= form_with model: @student || Student.new, url: @student ? student_path(@student) : students_path, local: true, multipart: true, class: "space-y-6" do |f| %>
  <% if @errors&.any? %>
    <div class="alert alert-error">
      <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <h3 class="font-bold">Please fix the following errors:</h3>
        <ul class="list-disc list-inside">
          <% @errors.each do |error| %>
            <li><%= error %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <%# User Information %>
  <div class="card bg-gray-800 border border-gray-700 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-xl mb-4 text-gray-100">User Account Information</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <%= fields_for :user, @student&.user || User.new do |user_form| %>
          <div class="form-control">
            <%= user_form.label :email_address, class: "label" do %>
              <span class="label-text text-gray-300">Email Address <span class="text-error">*</span></span>
            <% end %>
            <%= user_form.email_field :email_address, 
                value: @student&.user&.email_address,
                class: "input input-bordered w-full",
                required: true %>
          </div>

          <div class="form-control">
            <%= user_form.label :first_name, class: "label" do %>
              <span class="label-text text-gray-300">First Name <span class="text-error">*</span></span>
            <% end %>
            <%= user_form.text_field :first_name,
                value: @student&.user&.first_name,
                class: "input input-bordered w-full",
                required: true %>
          </div>

          <div class="form-control">
            <%= user_form.label :last_name, class: "label" do %>
              <span class="label-text text-gray-300">Last Name <span class="text-error">*</span></span>
            <% end %>
            <%= user_form.text_field :last_name,
                value: @student&.user&.last_name,
                class: "input input-bordered w-full",
                required: true %>
          </div>

          <div class="form-control">
            <%= user_form.label :phone_number, class: "label" do %>
              <span class="label-text text-gray-300">Phone Number</span>
            <% end %>
            <%= user_form.telephone_field :phone_number,
                value: @student&.user&.phone_number,
                class: "input input-bordered w-full" %>
          </div>

          <% unless @student %>
            <div class="form-control">
              <%= user_form.label :password, class: "label" do %>
                <span class="label-text text-gray-300">Password</span>
              <% end %>
              <%= user_form.password_field :password,
                  class: "input input-bordered w-full",
                  placeholder: "Leave blank for auto-generated password" %>
              <label class="label">
                <span class="label-text-alt text-gray-600">If left blank, a random password will be generated</span>
              </label>
            </div>

            <div class="form-control">
              <%= user_form.label :password_confirmation, class: "label" do %>
                <span class="label-text text-gray-300">Password Confirmation</span>
              <% end %>
              <%= user_form.password_field :password_confirmation,
                  class: "input input-bordered w-full" %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Student Information %>
  <div class="card bg-gray-800 border border-gray-700 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-xl mb-4 text-gray-100">Student Information</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <%= f.fields_for :student, @student || Student.new do |student_form| %>
          <div class="form-control">
            <%= f.label :date_of_birth, class: "label" do %>
              <span class="label-text text-gray-300">Date of Birth <span class="text-error">*</span></span>
            <% end %>
            <%= f.date_field :date_of_birth,
                value: @student&.date_of_birth,
                class: "input input-bordered w-full",
                required: true,
                max: Date.current %>
          </div>

          <div class="form-control">
            <%= f.label :admission_date, class: "label" do %>
              <span class="label-text text-gray-300">Admission Date</span>
            <% end %>
            <%= f.date_field :admission_date,
                value: @student&.admission_date || Date.current,
                class: "input input-bordered w-full" %>
          </div>

          <div class="form-control">
            <%= f.label :classroom_id, class: "label" do %>
              <span class="label-text text-gray-300">Classroom</span>
            <% end %>
            <%= f.select :classroom_id,
                options_from_collection_for_select(@classrooms, :id, :name, @student&.classroom_id),
                { include_blank: "Select classroom..." },
                { class: "select select-bordered w-full" } %>
          </div>

          <div class="form-control">
            <%= f.label :transport_route_id, class: "label" do %>
              <span class="label-text text-gray-300">Transport Route</span>
            <% end %>
            <%= f.select :transport_route_id,
                options_from_collection_for_select(@transport_routes || [], :id, :name, @student&.transport_route_id),
                { include_blank: "Select route..." },
                { class: "select select-bordered w-full" } %>
          </div>

          <div class="form-control">
            <%= f.label :blood_group, class: "label" do %>
              <span class="label-text text-gray-300">Blood Group</span>
            <% end %>
            <%= f.select :blood_group,
                options_for_select([
                  ["", ""],
                  ["A+", "A+"],
                  ["A-", "A-"],
                  ["B+", "B+"],
                  ["B-", "B-"],
                  ["AB+", "AB+"],
                  ["AB-", "AB-"],
                  ["O+", "O+"],
                  ["O-", "O-"]
                ], @student&.blood_group),
                {},
                { class: "select select-bordered w-full" } %>
          </div>

          <div class="form-control md:col-span-2">
            <%= f.label :photo, class: "label" do %>
              <span class="label-text text-gray-300">Photo</span>
            <% end %>
            <%= f.file_field :photo,
                accept: "image/*",
                class: "file-input file-input-bordered w-full" %>
            <% if @student&.photo&.attached? %>
              <label class="label">
                <span class="label-text-alt text-gray-600">Current photo will be replaced</span>
              </label>
            <% end %>
          </div>

          <div class="form-control md:col-span-2">
            <%= f.label :medical_conditions, class: "label" do %>
              <span class="label-text text-gray-300">Medical Conditions</span>
            <% end %>
            <%= f.text_area :medical_conditions,
                value: @student&.medical_conditions,
                class: "textarea textarea-bordered w-full",
                rows: 3,
                placeholder: "Any medical conditions or health issues..." %>
          </div>

          <div class="form-control md:col-span-2">
            <%= f.label :allergies, class: "label" do %>
              <span class="label-text text-gray-300">Allergies</span>
            <% end %>
            <%= f.text_area :allergies,
                value: @student&.allergies,
                class: "textarea textarea-bordered w-full",
                rows: 3,
                placeholder: "Any known allergies..." %>
          </div>

          <div class="form-control md:col-span-2">
            <%= f.label :special_needs, class: "label" do %>
              <span class="label-text text-gray-300">Special Needs</span>
            <% end %>
            <%= f.text_area :special_needs,
                value: @student&.special_needs,
                class: "textarea textarea-bordered w-full",
                rows: 3,
                placeholder: "Any special educational or physical needs..." %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Emergency Contact %>
  <div class="card bg-gray-800 border border-gray-700 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-xl mb-4 text-gray-100">Emergency Contact</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-control">
          <%= f.label :emergency_contact_name, class: "label" do %>
            <span class="label-text text-gray-300">Contact Name</span>
          <% end %>
          <%= f.text_field :emergency_contact_name,
              value: @student&.emergency_contact_name,
              class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= f.label :emergency_contact_phone, class: "label" do %>
            <span class="label-text text-gray-300">Contact Phone</span>
          <% end %>
          <%= f.telephone_field :emergency_contact_phone,
              value: @student&.emergency_contact_phone,
              class: "input input-bordered w-full" %>
        </div>
      </div>
    </div>
  </div>

  <%# Parents/Guardians %>
  <div class="card bg-gray-800 border border-gray-700 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-xl mb-4 text-gray-100">Parents/Guardians</h2>
      <div class="form-control">
        <label class="label">
          <span class="label-text text-gray-300">Select Parents/Guardians</span>
        </label>
        <div class="space-y-2 max-h-60 overflow-y-auto border border-gray-700 rounded-lg p-4">
          <% @parents.each do |parent| %>
            <label class="flex items-center gap-3 cursor-pointer hover:bg-gray-700 p-2 rounded">
              <%= check_box_tag "parent_ids[]",
                  parent.id,
                  (@selected_parent_ids || []).include?(parent.id.to_s),
                  class: "checkbox checkbox-primary" %>
              <div class="flex-1">
                <p class="font-medium text-gray-100"><%= "#{parent.first_name} #{parent.last_name}" %></p>
                <p class="text-sm text-gray-600"><%= parent.email_address %></p>
              </div>
            </label>
          <% end %>
          <% if @parents.empty? %>
            <p class="text-gray-600 text-sm">No parents available. Create parent accounts first.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# Form Actions %>
  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", @student ? student_path(@student) : students_path, class: "btn btn-ghost", data: { turbo_frame: "_top" } %>
    <%= f.submit @student ? "Update Student" : "Create Student", class: "btn btn-primary" %>
  </div>
<% end %>
